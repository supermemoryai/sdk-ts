"use strict";

const { spawn, spawnSync } = require("node:child_process");
const {
  chmodSync,
  cpSync,
  existsSync,
  mkdirSync,
  mkdtempSync,
  rmSync,
  writeFileSync,
} = require("node:fs");
const { homedir, tmpdir } = require("node:os");
const { dirname, extname, join } = require("node:path");
const readline = require("node:readline");

const COLORS = {
  reset: "\x1b[0m",
  bold: "\x1b[1m",
  dim: "\x1b[2m",
  red: "\x1b[31m",
  green: "\x1b[32m",
  yellow: "\x1b[33m",
  cyan: "\x1b[36m",
};

const canColor = process.stdout.isTTY && !process.env.NO_COLOR;

function color(name, value) {
  if (!canColor) return String(value);
  return `${COLORS[name]}${value}${COLORS.reset}`;
}

function bold(value) {
  return color("bold", value);
}

function dim(value) {
  return color("dim", value);
}

function green(value) {
  return color("green", value);
}

function red(value) {
  return color("red", value);
}

function yellow(value) {
  return color("yellow", value);
}

function cyan(value) {
  return color("cyan", value);
}

const PLUGIN_IDS = ["claude", "cursor", "opencode", "codex"];
const ALIASES = {
  claude: "claude",
  "claude-code": "claude",
  cursor: "cursor",
  opencode: "opencode",
  "open-code": "opencode",
  codex: "codex",
};

function cursorDetectionPaths() {
  const paths = [join(homedir(), ".cursor")];
  if (process.platform === "darwin") {
    paths.push("/Applications/Cursor.app");
    paths.push(join(homedir(), "Applications", "Cursor.app"));
  }
  return paths;
}

const TARGETS = [
  {
    id: "claude",
    label: "Claude Code",
    hint: "Installs the Supermemory Claude plugin through Claude Code",
    commands: ["claude"],
    paths: [],
  },
  {
    id: "cursor",
    label: "Cursor",
    hint: "Installs the local Cursor plugin bundle",
    commands: ["cursor", "agent"],
    paths: cursorDetectionPaths(),
  },
  {
    id: "opencode",
    label: "OpenCode",
    hint: "Runs the OpenCode Supermemory installer",
    commands: ["opencode"],
    paths: [join(homedir(), ".config", "opencode")],
  },
  {
    id: "codex",
    label: "Codex",
    hint: "Runs the Codex Supermemory installer",
    commands: ["codex"],
    paths: [join(homedir(), ".codex")],
  },
];

const CURSOR_PLUGIN_TARGET = join(
  homedir(),
  ".cursor",
  "plugins",
  "local",
  "cursor-supermemory",
);

class CommandError extends Error {
  constructor(message, log) {
    super(message);
    this.log = log;
  }
}

function usage() {
  process.stdout.write(`supermemory plugin

Install Supermemory integrations for Claude Code, Cursor, OpenCode, and Codex.

Usage:
  supermemory plugin
  supermemory plugin --all
  supermemory plugin --only claude,cursor

Options:
  --all              Install every detected plugin target.
  --only <targets>   Comma-separated targets: claude,cursor,opencode,codex.
  --dry-run          Show what would run without installing anything.
  --force            Run selected installers even when a target is not detected.
  --json             Print machine-readable output. Only supported with --dry-run.
  --help, -h         Show this help.

Interactive selection:
  Use Up/Down to move, Space to toggle custom choices, Enter to confirm,
  and Esc to return from custom selection to install mode.
`);
}

function parseArgs(argv) {
  const args = {
    all: false,
    only: undefined,
    dryRun: false,
    force: false,
    json: false,
    help: false,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--all") args.all = true;
    else if (arg === "--dry-run") args.dryRun = true;
    else if (arg === "--force") args.force = true;
    else if (arg === "--json") args.json = true;
    else if (arg === "--help" || arg === "-h") args.help = true;
    else if (arg === "--only") args.only = argv[++i] || "";
    else if (arg.startsWith("--only=")) args.only = arg.slice("--only=".length);
    else throw new Error(`unknown option ${arg}`);
  }

  return args;
}

function findCommand(command) {
  const result =
    process.platform === "win32"
      ? spawnSync("where.exe", [command], { encoding: "utf8" })
      : spawnSync("sh", ["-lc", `command -v ${shellQuote(command)}`], {
          encoding: "utf8",
        });

  if (result.status !== 0) return null;
  const candidates = String(result.stdout || "")
    .split(/\r?\n/)
    .filter(Boolean);

  if (process.platform !== "win32") return candidates[0] || null;

  const runnableExtensions = new Set([".cmd", ".exe", ".bat", ".com"]);
  const runnableCandidate = candidates.find((candidate) =>
    runnableExtensions.has(extname(candidate).toLowerCase()),
  );
  if (runnableCandidate) return runnableCandidate;

  for (const candidate of candidates) {
    if (extname(candidate)) return candidate;
    for (const extension of runnableExtensions) {
      const expanded = `${candidate}${extension}`;
      if (existsSync(expanded)) return expanded;
    }
  }

  return null;
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, "'\\''")}'`;
}

function detectTarget(target) {
  const reasons = [];

  for (const command of target.commands) {
    if (findCommand(command)) {
      reasons.push(`${command} on PATH`);
      break;
    }
  }

  for (const path of target.paths) {
    if (existsSync(path)) {
      reasons.push("local config");
      break;
    }
  }

  return {
    available: reasons.length > 0,
    reasons,
  };
}

function detectionSource(detection) {
  if (!detection || !detection.available) return "not detected";
  const command = detection.reasons.find((reason) => reason.endsWith(" on PATH"));
  const hasLocal = detection.reasons.includes("local config");
  const parts = [];
  if (command) parts.push(`command ${command.replace(" on PATH", "")}`);
  if (hasLocal) parts.push("local config");
  return parts.join(" or ") || "detected";
}

function printDetectionSummary(detections) {
  process.stderr.write(`\n  ${bold("Detected integrations:")}\n`);
  for (const target of TARGETS) {
    const detection = detections.get(target.id);
    if (detection && detection.available) {
      process.stderr.write(
        `    ${green("[ready]")} ${bold(target.label)} ${dim(detectionSource(detection))}\n`,
      );
    } else {
      process.stderr.write(
        `    ${red("[missing]")} ${bold(target.label)} ${dim("not detected")}\n`,
      );
    }
  }
  process.stderr.write("\n");
}

function parseOnly(value) {
  if (!value) return [];
  const ids = [];
  const unknown = [];

  for (const raw of String(value).split(",")) {
    const key = raw.trim().toLowerCase();
    if (!key) continue;
    const id = ALIASES[key];
    if (!id) {
      unknown.push(raw.trim());
      continue;
    }
    if (!ids.includes(id)) ids.push(id);
  }

  if (unknown.length > 0) {
    throw new Error(
      `Unknown plugin selection: ${unknown.join(", ")}. Use claude, cursor, opencode, or codex.`,
    );
  }

  return ids;
}

function readyTargetIds(detections) {
  return TARGETS.filter((target) => detections.get(target.id)?.available).map(
    (target) => target.id,
  );
}

function hideCursor() {
  if (process.stdout.isTTY) process.stdout.write("\x1b[?25l");
}

function showCursor() {
  if (process.stdout.isTTY) process.stdout.write("\x1b[?25h");
}

function clearRendered(lines) {
  if (!process.stdout.isTTY || lines <= 0) return;
  for (let i = 0; i < lines; i += 1) {
    process.stdout.write("\x1b[2K\r");
    if (i < lines - 1) process.stdout.write("\x1b[1A");
  }
}

function enableRawInput(onKey) {
  readline.emitKeypressEvents(process.stdin);
  if (process.stdin.isTTY) process.stdin.setRawMode(true);
  process.stdin.resume();
  process.stdin.on("keypress", onKey);

  return () => {
    process.stdin.off("keypress", onKey);
    if (process.stdin.isTTY) process.stdin.setRawMode(false);
    process.stdin.pause();
  };
}

function selectPrompt({ message, options, initialIndex = 0 }) {
  if (!process.stdin.isTTY || !process.stdout.isTTY) {
    return Promise.reject(new Error("Interactive selection requires a TTY"));
  }

  return new Promise((resolve) => {
    let index = initialIndex;
    let renderedLines = 0;

    function render() {
      clearRendered(renderedLines);
      const lines = [`${cyan("?")} ${bold(message)}`];
      options.forEach((option, optionIndex) => {
        const pointer = optionIndex === index ? cyan(">") : " ";
        const hint = option.hint ? ` ${dim(`(${option.hint})`)}` : "";
        lines.push(`  ${pointer} ${option.label}${hint}`);
      });
      renderedLines = lines.length;
      process.stdout.write(`${lines.join("\n")}\n`);
    }

    hideCursor();
    const cleanup = enableRawInput((_str, key) => {
      if (key.name === "up") {
        index = (index - 1 + options.length) % options.length;
        render();
      } else if (key.name === "down") {
        index = (index + 1) % options.length;
        render();
      } else if (key.name === "return") {
        cleanup();
        clearRendered(renderedLines);
        showCursor();
        const option = options[index];
        process.stdout.write(`${green(">")} ${bold(message)}\n  ${option.label}\n`);
        resolve(option.value);
      } else if (key.name === "escape" || (key.ctrl && key.name === "c")) {
        cleanup();
        clearRendered(renderedLines);
        showCursor();
        process.stdout.write(`${yellow("!")} Install cancelled.\n`);
        process.exit(0);
      }
    });

    render();
  });
}

function multiSelectPrompt({ message, options }) {
  if (!process.stdin.isTTY || !process.stdout.isTTY) {
    return Promise.reject(new Error("Interactive selection requires a TTY"));
  }

  return new Promise((resolve) => {
    let index = 0;
    const selected = new Set();
    let renderedLines = 0;

    function render() {
      clearRendered(renderedLines);
      const lines = [`${cyan("?")} ${bold(message)}`];
      options.forEach((option, optionIndex) => {
        const pointer = optionIndex === index ? cyan(">") : " ";
        const checked = selected.has(option.value) ? green("[x]") : dim("[ ]");
        const hint = option.hint ? ` ${dim(`(${option.hint})`)}` : "";
        lines.push(`  ${pointer} ${checked} ${option.label}${hint}`);
      });
      renderedLines = lines.length;
      process.stdout.write(`${lines.join("\n")}\n`);
    }

    hideCursor();
    const cleanup = enableRawInput((_str, key) => {
      if (key.name === "up") {
        index = (index - 1 + options.length) % options.length;
        render();
      } else if (key.name === "down") {
        index = (index + 1) % options.length;
        render();
      } else if (key.name === "space") {
        const value = options[index].value;
        if (selected.has(value)) selected.delete(value);
        else selected.add(value);
        render();
      } else if (key.name === "return") {
        if (selected.size === 0) {
          render();
          process.stdout.write(`  ${yellow("Select at least one integration with Space.")}\n`);
          renderedLines += 1;
          return;
        }
        cleanup();
        clearRendered(renderedLines);
        showCursor();
        const values = [...selected];
        const labels = options
          .filter((option) => selected.has(option.value))
          .map((option) => option.label.replace(/\s+\[.*?\]$/, ""));
        process.stdout.write(`${green(">")} ${bold(message)}\n  ${labels.join(", ")}\n`);
        resolve(values);
      } else if (key.name === "escape") {
        cleanup();
        clearRendered(renderedLines);
        showCursor();
        resolve(null);
      } else if (key.ctrl && key.name === "c") {
        cleanup();
        clearRendered(renderedLines);
        showCursor();
        process.stdout.write(`${yellow("!")} Install cancelled.\n`);
        process.exit(0);
      }
    });

    render();
  });
}

function optionLabel(target, detection) {
  if (detection && detection.available) return `${target.label} ${green("[ready]")}`;
  return `${target.label} ${red("[missing]")}`;
}

async function chooseTargetsInteractively(detections) {
  printDetectionSummary(detections);
  process.stderr.write(`  ${dim("tip: use Up/Down to move, Enter to confirm")}\n`);
  process.stderr.write(
    `  ${dim("tip: custom selection uses Space to toggle, Esc to return to install mode")}\n`,
  );
  process.stderr.write(`  ${dim("tip: scripts can use")} supermemory plugin --all\n\n`);

  const readyIds = readyTargetIds(detections);
  const modeOptions = [{ value: "custom", label: "Custom selection", hint: "pick plugins with Space" }];
  if (readyIds.length > 0) {
    modeOptions.unshift({
      value: "all",
      label: cyan("Install all ready integrations"),
      hint: `${readyIds.length} ready`,
    });
  }

  const mode = await selectPrompt({ message: "Install mode", options: modeOptions });
  if (mode === "all") return readyIds;

  const options = TARGETS.map((target) => ({
    value: target.id,
    label: optionLabel(target, detections.get(target.id)),
    hint: target.hint,
  }));

  const selected = await multiSelectPrompt({
    message: "Choose integrations to install",
    options,
  });

  if (!selected) return chooseTargetsInteractively(detections);
  return selected;
}

function quoteWindowsArg(value) {
  if (!/[ \t"&|<>^]/.test(value)) return value;
  return `"${String(value).replace(/"/g, '""')}"`;
}

function trimLog(stdout, stderr) {
  const combined = `${stdout}${stderr ? `\n${stderr}` : ""}`.trim();
  if (!combined) return undefined;
  const lines = combined.split(/\r?\n/);
  return lines.slice(Math.max(0, lines.length - 20)).join("\n");
}

function runProcess(command, args) {
  return new Promise((resolve, reject) => {
    const resolvedCommand = findCommand(command) || command;
    const extension = extname(resolvedCommand).toLowerCase();
    const useCmd = process.platform === "win32" && [".cmd", ".bat"].includes(extension);

    const child = useCmd
      ? spawn(
          process.env.ComSpec || "cmd.exe",
          [
            "/d",
            "/s",
            "/c",
            [quoteWindowsArg(resolvedCommand), ...args.map(quoteWindowsArg)].join(" "),
          ],
          { stdio: ["ignore", "pipe", "pipe"] },
        )
      : spawn(resolvedCommand, args, { stdio: ["ignore", "pipe", "pipe"] });

    let stdout = "";
    let stderr = "";
    child.stdout?.on("data", (chunk) => {
      stdout += chunk.toString();
    });
    child.stderr?.on("data", (chunk) => {
      stderr += chunk.toString();
    });
    child.on("error", reject);
    child.on("close", (code) => {
      if (code === 0) {
        resolve(trimLog(stdout, stderr));
      } else {
        reject(new CommandError(`${command} ${args.join(" ")} exited with ${code}`, trimLog(stdout, stderr)));
      }
    });
  });
}

function formatStep(command, args) {
  return [command, ...args].join(" ");
}

function startSpinner(message) {
  if (!process.stderr.isTTY) {
    process.stderr.write(`${message}\n`);
    return { message() {}, stop() {}, fail() {} };
  }

  const frames = ["-", "\\", "|", "/"];
  let index = 0;
  let current = message;
  process.stderr.write(`${frames[index]} ${current}`);
  const timer = setInterval(() => {
    index = (index + 1) % frames.length;
    process.stderr.write(`\r${frames[index]} ${current}\x1b[K`);
  }, 80);

  return {
    message(next) {
      current = next;
    },
    stop(finalMessage) {
      clearInterval(timer);
      process.stderr.write(`\r${green("[ok]")} ${finalMessage || current}\x1b[K\n`);
    },
    fail(finalMessage) {
      clearInterval(timer);
      process.stderr.write(`\r${red("[fail]")} ${finalMessage || current}\x1b[K\n`);
    },
  };
}

async function installCursorPlugin(dryRun) {
  const steps = [
    "npm install cursor-supermemory@latest into a temporary directory",
    "copy cursor-supermemory package files into Cursor's local plugin directory",
  ];

  if (dryRun) return steps;

  const tempDir = mkdtempSync(join(tmpdir(), "supermemory-cursor-plugin-"));
  try {
    await runProcess("npm", [
      "install",
      "cursor-supermemory@latest",
      "--omit=dev",
      "--ignore-scripts",
      "--no-audit",
      "--no-fund",
      "--prefix",
      tempDir,
    ]);

    const packageDir = join(tempDir, "node_modules", "cursor-supermemory");
    if (!existsSync(join(packageDir, ".cursor-plugin", "plugin.json"))) {
      throw new Error("Downloaded cursor-supermemory package is missing .cursor-plugin/plugin.json");
    }

    mkdirSync(dirname(CURSOR_PLUGIN_TARGET), { recursive: true });
    rmSync(CURSOR_PLUGIN_TARGET, { recursive: true, force: true });
    cpSync(packageDir, CURSOR_PLUGIN_TARGET, { recursive: true });
  } finally {
    rmSync(tempDir, { recursive: true, force: true });
  }

  return steps;
}

function installLine(target) {
  switch (target.id) {
    case "claude":
      return "Threading Supermemory into Claude Code...";
    case "cursor":
      return "Packing memories into Cursor's local plugin shelf...";
    case "opencode":
      return "Teaching OpenCode where the memory lives...";
    case "codex":
      return "Wiring Codex into the Supermemory recall loop...";
    default:
      return `Installing ${target.label}...`;
  }
}

async function installTarget(target, dryRun) {
  const steps = [];
  const spinner = dryRun ? null : startSpinner(installLine(target));

  try {
    let log;

    if (target.id === "claude") {
      const addMarketplace = ["plugin", "marketplace", "add", "supermemoryai/claude-supermemory"];
      const installPlugin = ["plugin", "install", "supermemory@supermemory-plugins", "--scope", "user"];
      steps.push(formatStep("claude", addMarketplace));
      steps.push(formatStep("claude", installPlugin));
      if (!dryRun) {
        spinner?.message("Adding Supermemory marketplace to Claude Code...");
        log = await runProcess("claude", addMarketplace);
        spinner?.message("Installing Supermemory in Claude Code...");
        log = (await runProcess("claude", installPlugin)) || log;
      }
    }

    if (target.id === "cursor") {
      spinner?.message("Installing Cursor plugin bundle...");
      steps.push(...(await installCursorPlugin(dryRun)));
    }

    if (target.id === "opencode") {
      const args = ["-y", "opencode-supermemory@latest", "install", "--no-tui"];
      steps.push(formatStep("npx", args));
      if (!dryRun) log = (await runProcess("npx", args)) || log;
    }

    if (target.id === "codex") {
      const args = ["-y", "codex-supermemory@latest", "install"];
      steps.push(formatStep("npx", args));
      if (!dryRun) log = (await runProcess("npx", args)) || log;
    }

    spinner?.stop(`${target.label} installed`);
    return {
      id: target.id,
      label: target.label,
      status: dryRun ? "planned" : "installed",
      message:
        target.id === "cursor"
          ? `Cursor plugin ${dryRun ? "would be installed" : "installed"}. Restart Cursor or run Developer: Reload Window.`
          : `${target.label} ${dryRun ? "install planned" : "install complete"}.`,
      steps,
      log,
    };
  } catch (error) {
    spinner?.fail(`${target.label} failed`);
    return {
      id: target.id,
      label: target.label,
      status: "failed",
      message: error instanceof Error ? error.message : String(error),
      steps,
      log: error instanceof CommandError ? error.log : undefined,
    };
  }
}

function printHumanSummary(results, dryRun) {
  const title = dryRun ? "Supermemory plugin install plan" : "Supermemory plugin install summary";
  process.stdout.write(`\n${bold(title)}\n\n`);

  if (results.length === 0) {
    process.stdout.write(`${yellow("[skip]")} No ready integrations were detected.\n`);
    process.stdout.write(`  ${dim("Install a supported coding agent, or rerun with --only <target> --force.")}\n\n`);
    return;
  }

  for (const result of results) {
    const icon =
      result.status === "installed"
        ? green("[ok]")
        : result.status === "planned"
          ? cyan("[plan]")
          : result.status === "skipped"
            ? yellow("[skip]")
            : red("[fail]");

    process.stdout.write(`${icon} ${bold(result.label)}: ${result.message}\n`);
    for (const step of result.steps) {
      process.stdout.write(`  ${dim(step)}\n`);
    }
    if (result.log && result.status === "failed") {
      process.stdout.write(`  ${dim("Last output:")}\n`);
      for (const line of result.log.split(/\r?\n/)) {
        process.stdout.write(`  ${dim(line)}\n`);
      }
    }
    process.stdout.write("\n");
  }

  if (results.some((result) => result.id === "claude" && result.status !== "skipped")) {
    process.stdout.write(
      `  ${dim("Claude reload:")} run ${bold("/reload-plugins")} inside any already-open Claude Code session.\n\n`,
    );
  }
}

async function run(argv) {
  const args = parseArgs(argv);
  if (args.help) {
    usage();
    return;
  }
  if (args.json && !args.dryRun) {
    throw new Error("--json is only supported with --dry-run for plugin");
  }

  const detections = new Map(TARGETS.map((target) => [target.id, detectTarget(target)]));

  let selectedIds = parseOnly(args.only);
  if (args.all) {
    selectedIds = TARGETS.filter((target) => args.force || detections.get(target.id)?.available).map(
      (target) => target.id,
    );
  }

  if (selectedIds.length === 0 && !args.all) {
    if (!process.stdin.isTTY) {
      throw new Error("Choose targets with --all or --only claude,cursor,opencode,codex");
    }
    selectedIds = await chooseTargetsInteractively(detections);
  }

  const results = [];
  for (const id of selectedIds) {
    const target = TARGETS.find((candidate) => candidate.id === id);
    if (!target) continue;

    const detection = detections.get(id);
    if (!args.force && !detection?.available) {
      results.push({
        id,
        label: target.label,
        status: "skipped",
        message: "not detected on this machine; use --force to install anyway",
        steps: [],
      });
      continue;
    }

    results.push(await installTarget(target, args.dryRun));
  }

  if (args.json) {
    process.stdout.write(`${JSON.stringify({ results }, null, 2)}\n`);
  } else {
    printHumanSummary(results, args.dryRun);
  }

  if (results.some((result) => result.status === "failed")) {
    process.exitCode = 1;
  }
}

module.exports = { run };
