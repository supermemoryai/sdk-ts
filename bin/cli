          value += `
`;
        else
          sep3 = `
`;
      } else {
        value += sep3 + content;
        sep3 = " ";
        prevMoreIndented = false;
      }
    }
    switch (header.chomp) {
      case "-":
        break;
      case "+":
        for (let i2 = chompStart;i2 < lines.length; ++i2)
