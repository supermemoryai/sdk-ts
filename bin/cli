// src/lib/output.ts
var EXIT = {
  SUCCESS: 0,
  ERROR: 1,
  AUTH_REQUIRED: 2,
  PERMISSION_DENIED: 3,
  NOT_FOUND: 4
};
function isInteractive() {
  return process.stdout.isTTY === true;
}
function isInputInteractive() {
  return process.stdin.isTTY === true;
}
function shouldOutputJson(flags) {
  if (flags.json)
    return true;
  return !isInteractive();
}
function output(data, humanFormatter, flags) {
  if (shouldOutputJson(flags)) {
    process.stdout.write(`${JSON.stringify(data, null, 2)}
`);
  } else {
    process.stdout.write(`${humanFormatter(data)}
`);
  }
}
function info(message, flags) {
  if (shouldOutputJson(flags))
    return;
  process.stdout.write(`  ${message}
`);
}
function error(code, message, flags, hint) {
  if (shouldOutputJson(flags)) {
    process.stderr.write(`${JSON.stringify({ error: code, message, ...hint ? { hint } : {} })}
`);
  } else {
    process.stderr.write(`${source_default.red("✗")} Error: ${message}
`);
    if (hint) {
      process.stderr.write(`  ${source_default.dim(`hint: ${hint}`)}
`);
    }
  }
}
function exitWithError(code, message, flags, exitCode = EXIT.ERROR, hint) {
  error(code, message, flags, hint);
  process.exit(exitCode);
}
var ANSI_RE = /\x1B\[[0-9;]*m/g;
function visualLength(str) {
  return str.replace(ANSI_RE, "").length;
}
function truncate(str, max) {
  if (str.length <= max)
    return str;
  return `${str.slice(0, max - 1)}…`;
}
function formatTable(headers, rows, columnWidths) {
  const cellLengths = rows.map((row) => row.map((cell) => visualLength(cell ?? "")));
  const widths = columnWidths ?? headers.map((h2, i2) => Math.max(h2.length, ...cellLengths.map((lens) => lens[i2] ?? 0)));
  const headerLine = headers.map((h2, i2) => h2.padEnd(widths[i2] ?? 0)).join("  ");
  const lines = rows.map((row, rowIdx) => row.map((cell, i2) => {
    const c3 = cell ?? "";
    const pad = (widths[i2] ?? 0) - (cellLengths[rowIdx]?.[i2] ?? 0);
    return pad > 0 ? c3 + " ".repeat(pad) : c3;
  }).join("  "));
  return `  ${source_default.dim(headerLine)}
${lines.map((l2) => `  ${l2}`).join(`
`)}`;
}
function formatKeyValue(pairs) {
  const maxKeyLen = Math.max(...pairs.map(([k2]) => k2.length));
  return pairs.map(([key, value]) => `  ${source_default.dim(key.padEnd(maxKeyLen + 1))} ${value}`).join(`
`);
}
function formatRelativeTime(date) {
  const d2 = typeof date === "string" ? new Date(date) : date;
  const now = Date.now();
  const diff = now - d2.getTime();
  const seconds = Math.floor(diff / 1000);
  const minutes = Math.floor(seconds / 60);
  const hours = Math.floor(minutes / 60);
  const days = Math.floor(hours / 24);
  if (days > 0)
    return `${days}d ago`;
  if (hours > 0)
    return `${hours}h ago`;
  if (minutes > 0)
    return `${minutes}m ago`;
  return "just now";
}
function formatProgressBar(current, total, width = 13) {
  const ratio = Math.min(current / total, 1);
  const filled = Math.round(ratio * width);
  const empty = width - filled;
  const bar = "█".repeat(filled) + "░".repeat(empty);
  const pct = Math.round(ratio * 100);
  return `${bar}  ${pct}%`;
}
function maskApiKey(key) {
  if (key.length < 12)
    return "****";
  const prefix = key.slice(0, key.indexOf("_", 3) + 1);
  const start = key.slice(prefix.length, prefix.length + 4);
  return `${prefix}${start}****`;
}

