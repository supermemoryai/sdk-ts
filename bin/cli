    ].includes(sub))
      return;
    await runCommand(connectorsListCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: list, connect, sync, history, disconnect, resources. Run supermemory connectors --help for details.")}
`);
  }
});

// src/commands/docs.ts
var PIPELINE_STAGES = [
  "queued",
  "extracting",
  "chunking",
  "embedding",
  "indexing",
  "done"
];
var docsListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List documents"
  },
  args: {
    tag: {
      type: "string",
      description: "Filter by container tag"
    },
    limit: {
      type: "string",
      description: "Max results (default: 20)"
    },
    page: {
      type: "string",
      description: "Page number for pagination"
    }
  },
  async handler({ args, flags }) {
    const query = {};
    if (args.tag)
      query.containerTag = args.tag;
    query.limit = parseIntArg(args.limit, "limit", {
      min: 1
    });
    query.page = parseIntArg(args.page, "page", {
      min: 1
    });
    const { data } = await apiRequest("/v3/documents", { query });
    output(data, () => {
      const results = data.results ?? [];
      if (results.length === 0) {
        return "  No documents found.";
      }
      return formatTable(["ID", "TITLE", "STATUS", "TAG", "CREATED"], results.map((doc) => {
        return [
          doc.id,
          truncate(doc.title ?? "", 40),
          doc.status,
          doc.containerTag ?? "",
          formatRelativeTime(doc.createdAt)
        ];
      }));
    }, flags);
  }
});
var docsGetCommand = defineCliCommand({
  meta: {
    name: "get",
    description: "Get a document by ID"
  },
  args: {
    id: {
      type: "positional",
      description: "Document ID",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data } = await apiRequest(`/v3/documents/${args.id}`);
    output(data, () => {
      const contentPreview = data.content ? truncate(data.content, 200) : "";
      return formatKeyValue([
        ["ID:", data.id],
        ["Title:", data.title ?? ""],
        ["Status:", data.status],
        ["Tag:", data.containerTag ?? ""],
        ["Content:", contentPreview],
        ["Created:", formatRelativeTime(data.createdAt)],
        [
          "Updated:",
          data.updatedAt ? formatRelativeTime(data.updatedAt) : ""
        ]
      ]);
    }, flags);
  }
});
var docsDeleteCommand = defineCliCommand({
  meta: {
    name: "delete",
    description: "Delete a document by ID"
  },
  args: {
    id: {
      type: "positional",
      description: "Document ID",
      required: true
    },
    yes: {
      type: "boolean",
      description: "Skip confirmation",
      default: false
    }
  },
  async handler({ args, flags, span }) {
    if (!args.yes) {
      const readline = await import("node:readline");
      const rl = readline.createInterface({
        input: process.stdin,
        output: process.stderr
      });
      const answer = await new Promise((resolve4) => {
        rl.question(`${source_default.yellow("?")} Delete document ${source_default.bold(args.id)}? (y/N) `, resolve4);
      });
      rl.close();
      if (answer.toLowerCase() !== "y") {
        exitWithError("cancelled", "Delete cancelled", flags);
      }
    }
    span.setAttribute("documentId", args.id);
    const { data } = await apiRequest(`/v3/documents/${args.id}`, { method: "DELETE" });
    output(data, () => `${source_default.green("✓")} Deleted document ${source_default.dim(args.id)}`, flags);
  }
});
var docsChunksCommand = defineCliCommand({
  meta: {
    name: "chunks",
    description: "List chunks for a document"
  },
  args: {
    id: {
      type: "positional",
      description: "Document ID",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data } = await apiRequest(`/v3/documents/${args.id}/chunks`);
    output(data, () => {
      const chunks = data.chunks ?? [];
      if (chunks.length === 0) {
        return "  No chunks found.";
      }
      return chunks.map((chunk) => {
        const preview = truncate(chunk.content, 100);
        return `  ${source_default.dim(`${chunk.index}.`)} ${preview}`;
      }).join(`

`);
    }, flags);
  }
});
var docsStatusCommand = defineCliCommand({
  meta: {
    name: "status",
    description: "Show document pipeline status"
  },
  args: {
    id: {
      type: "positional",
      description: "Document ID",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data } = await apiRequest(`/v3/documents/${args.id}`);
    const isFailed = data.status === "failed";
    const isUnknown = data.status === "unknown";
    const currentIndex = PIPELINE_STAGES.indexOf(data.status);
    const progress = isFailed ? 0 : currentIndex >= 0 ? Math.round((currentIndex + 1) / PIPELINE_STAGES.length * 100) : 0;
    output({ id: data.id, status: data.status, progress }, () => {
      if (isFailed) {
        const lines2 = PIPELINE_STAGES.map((stage) => `  ${source_default.dim("○")} ${source_default.dim(stage)}`);
        return `  Document ${source_default.bold(data.id)}

${lines2.join(`
`)}

  ${source_default.red("✗")} Processing failed`;
      }
      if (isUnknown) {
        return `  Document ${source_default.bold(data.id)}

  ${source_default.yellow("?")} Status unknown`;
      }
      const lines = PIPELINE_STAGES.map((stage, i2) => {
        if (i2 < currentIndex) {
          return `  ${source_default.green("✓")} ${stage}`;
        }
        if (i2 === currentIndex) {
          return `  ${source_default.cyan("▶")} ${source_default.bold(stage)}`;
        }
        return `  ${source_default.dim("○")} ${source_default.dim(stage)}`;
      });
      return `  Document ${source_default.bold(data.id)}

${lines.join(`
`)}`;
    }, flags);
  }
});
var docsCommand = defineCommand({
  meta: {
    name: "docs",
    description: "Manage documents"
  },
  subCommands: {
    list: docsListCommand,
    get: docsGetCommand,
    delete: docsDeleteCommand,
    chunks: docsChunksCommand,
    status: docsStatusCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && ["list", "get", "delete", "chunks", "status"].includes(sub))
      return;
    await runCommand(docsListCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: list, get, delete, chunks, status. Run supermemory docs --help for details.")}
`);
  }
});

// src/commands/forget.ts
var forgetCommand = defineCliCommand({
  meta: {
    name: "forget",
    description: "Forget a specific memory"
  },
  args: {
    id: {
      type: "positional",
      description: "Memory ID",
      required: false
    },
    tag: {
      type: "string",
      description: "Container tag (required)"
    },
    reason: {
      type: "string",
      description: "Reason for forgetting"
    },
    content: {
      type: "string",
      description: "Find and forget by content match (instead of ID)"
    }
  },
  async handler({ args, flags, config, span }) {
    const tag = args.tag ?? config.tag;
    if (!tag) {
      throw new ValidationError("Container tag required. Use --tag <name>");
    }
    if (!args.id && !args.content) {
      exitWithError("validation_error", "Either a memory ID or --content is required", flags);
    }
    const body = {};
    body.containerTag = tag;
    if (args.id)
      body.id = args.id;
    if (args.reason)
      body.reason = args.reason;
    if (args.content)
      body.content = args.content;
    span.setAttribute("memoryId", args.id ?? "content-match");
    const { data } = await apiRequest("/v4/memories", {
      method: "DELETE",
      body
    });
    output(data, () => `${source_default.green("✓")} Forgot memory ${source_default.dim(args.id ?? "(by content)")}`, flags);
  }
});

// src/commands/init.ts
var import_node_path5 = require("node:path");

// src/lib/prompt.ts
var import_node_readline2 = require("node:readline");
function createPromptSession() {
  const rl = import_node_readline2.createInterface({
    input: process.stdin,
    output: process.stderr
  });
  rl.on("close", () => {
    process.exit(0);
  });
  function question(prompt2) {
    return new Promise((resolve4) => {
      rl.question(prompt2, resolve4);
    });
  }
  return {
    async ask(label, opts) {
      const defaultDisplay = opts?.default ? ` [${opts.default}]` : "";
      const hint = opts?.hint ? ` ${opts.hint}` : "";
      const answer = await question(`  ${label}${defaultDisplay}${hint}: `);
      const trimmed = answer.trim();
      return trimmed || opts?.default || "";
    },
    async select(label, options, defaultIndex = 0) {
      const defaultDisplay = ` [${defaultIndex + 1}]`;
      const defaultOpt = options[defaultIndex];
      process.stderr.write(`  ${label}${defaultDisplay}:
`);
      for (let i2 = 0;i2 < options.length; i2++) {
        const opt = options[i2];
        if (!opt)
          continue;
        const hint = opt.hint ? ` — ${opt.hint}` : "";
        process.stderr.write(`    ${i2 + 1}. ${opt.label}${hint}
`);
      }
      const answer = await question("  > ");
      const trimmed = answer.trim();
      if (!trimmed) {
        return defaultOpt?.value ?? "";
      }
      const num = Number.parseInt(trimmed, 10);
      if (Number.isNaN(num) || num < 1 || num > options.length) {
        process.stderr.write(`  Invalid selection. Using default: ${defaultOpt?.label}
`);
        return defaultOpt?.value ?? "";
      }
      return options[num - 1]?.value ?? "";
    },
    close() {
      rl.removeAllListeners("close");
      rl.close();
    }
  };
}

// src/commands/init.ts
var initCommand = defineCliCommand({
  meta: {
    name: "init",
    description: "Initialize Supermemory configuration for this project"
  },
  noSpan: true,
  args: {
    scope: {
      type: "string",
      description: "Config scope: project, team, global"
    },
    tag: {
      type: "string",
      description: "Container tag"
    },
    "api-key": {
      type: "string",
      description: "API key (project scope only)"
    },
    output: {
      type: "string",
      description: "Output format: auto, json, human (global only)"
    },
    "api-url": {
      type: "string",
      description: "API URL (global only)"
    },
    "console-url": {
      type: "string",
      description: "Console URL (global only)"
    }
  },
  async handler({ args, flags }) {
    const hasFlags = args.scope || args.tag || args["api-key"] || args.output || args["api-url"] || args["console-url"];
    const interactive = isInputInteractive() && !hasFlags;
    if (interactive) {
      await runInteractive(flags);
    } else {
      await runNonInteractive(args, flags);
    }
  }
});
async function runInteractive(flags) {
  const session = createPromptSession();
  const auth = getAuthState();
  const config = resolveConfig();
  try {
    process.stderr.write(`
`);
    process.stderr.write(`  ${source_default.dim("tip: AI agents can use flags directly — run")} supermemory init --help
`);
    process.stderr.write(`
`);
    process.stderr.write(`  ${source_default.bold("Current config:")}
`);
    process.stderr.write(`    API Key:  ${auth.apiKey.masked ? `${auth.apiKey.masked}  ${source_default.dim(`(${auth.apiKey.source})`)}` : source_default.dim("(not set)")}
`);
    process.stderr.write(`    Tag:      ${auth.tag.value ? `${auth.tag.value}  ${source_default.dim(`(${auth.tag.source})`)}` : source_default.dim("(not set)")}
`);
    process.stderr.write(`
`);
    const scope = await session.select("Select scope", [
      {
        value: "project",
        label: "Project",
        hint: "just this directory, your machine"
      },
      {
        value: "team",
        label: "Team",
        hint: "shared with repo, committed to git"
      },
      {
        value: "global",
        label: "Global",
        hint: "applies everywhere"
      }
    ], 0);
    process.stderr.write(`
`);
    if (scope === "project") {
      await runProjectWizard(session, auth, config, flags);
    } else if (scope === "team") {
      await runTeamWizard(session, auth, flags);
    } else {
      await runGlobalWizard(session, config, flags);
    }
  } finally {
    session.close();
  }
}
async function runProjectWizard(session, auth, config, flags) {
  const existing = readProjectConfig();
  const apiKeyAnswer = await session.ask("API Key", {
    default: auth.apiKey.masked ?? undefined
  });
  let newApiKey;
  if (apiKeyAnswer && apiKeyAnswer !== auth.apiKey.masked) {
    try {
      await validateApiKey(apiKeyAnswer, config.apiUrl);
      newApiKey = apiKeyAnswer;
    } catch {
      exitWithError("invalid_api_key", "API key validation failed. Check your key and try again.", flags);
    }
  }
  const tagAnswer = await session.ask("Container Tag", {
    default: auth.tag.value ?? getDefaultTag()
  });
  const projectUpdates = {};
  if (newApiKey)
    projectUpdates.apiKey = newApiKey;
  if (tagAnswer && tagAnswer !== (existing?.tag ?? ""))
    projectUpdates.tag = tagAnswer;
  if (Object.keys(projectUpdates).length > 0 || !existing) {
    writeProjectConfig({ ...existing, ...projectUpdates });
  }
  const projectDir = getProjectConfigPath();
  output({
    scope: "project",
    tag: tagAnswer || null,
    apiKey: newApiKey ? "updated" : "unchanged",
    path: projectDir
  }, () => {
    const lines = ["", `${source_default.green("✓")} Configured (project scope)`];
    if (tagAnswer)
      lines.push(`  Tag: ${tagAnswer}`);
    if (newApiKey)
      lines.push("  API Key: updated");
    lines.push(`  Saved to ${source_default.dim(projectDir)}`);
    return lines.join(`
`);
  }, flags);
}
async function runTeamWizard(session, auth, flags) {
  const gitRoot = findGitRoot();
  if (!gitRoot) {
    exitWithError("not_git_repo", "Not in a git repository. Team config requires a git repo.", flags);
  }
  const existing = readTeamConfig();
  const tagAnswer = await session.ask("Container Tag", {
    default: auth.tag.value ?? getDefaultTag()
  });
  const updates = {};
  if (tagAnswer)
    updates.tag = tagAnswer;
  if (existing) {
    updateTeamConfig(updates);
  } else {
    initTeamConfig(updates);
  }
  const configPath = `${gitRoot}/.supermemory/config.json`;
  output({
    scope: "team",
    tag: tagAnswer || null,
    path: configPath
  }, () => {
    const lines = ["", `${source_default.green("✓")} Configured (team scope)`];
    if (tagAnswer)
      lines.push(`  Tag: ${tagAnswer}`);
    lines.push(`  Saved to ${source_default.dim(configPath)}`);
    lines.push(`  ${source_default.dim("Commit .supermemory/ to share config with your team.")}`);
    return lines.join(`
`);
  }, flags);
}
async function runGlobalWizard(session, config, flags) {
  const outputAnswer = await session.ask("Output format", {
    default: config.output,
    hint: source_default.dim("(auto, json, human)")
  });
  const apiUrlAnswer = await session.ask("API URL", {
    default: config.apiUrl
  });
  const consoleUrlAnswer = await session.ask("Console URL", {
    default: config.consoleUrl
  });
  const updates = {};
  if (outputAnswer && ["auto", "json", "human"].includes(outputAnswer))
    updates.output = outputAnswer;
  if (apiUrlAnswer)
    updates.apiUrl = apiUrlAnswer;
  if (consoleUrlAnswer)
    updates.consoleUrl = consoleUrlAnswer;
  if (Object.keys(updates).length > 0) {
    updateUserConfig(updates);
  }
  output({
    scope: "global",
    output: outputAnswer || null,
    apiUrl: apiUrlAnswer || null,
    consoleUrl: consoleUrlAnswer || null,
    path: "~/.supermemory/config.json"
  }, () => {
    const lines = ["", `${source_default.green("✓")} Configured (global scope)`];
    if (outputAnswer)
      lines.push(`  Output: ${outputAnswer}`);
    if (apiUrlAnswer)
      lines.push(`  API URL: ${apiUrlAnswer}`);
    if (consoleUrlAnswer)
      lines.push(`  Console URL: ${consoleUrlAnswer}`);
    lines.push(`  Saved to ${source_default.dim("~/.supermemory/config.json")}`);
    return lines.join(`
`);
  }, flags);
}
async function runNonInteractive(args, flags) {
  const scope = parseEnumArg(args.scope, "scope", [
    "project",
    "team",
    "global"
  ]);
  if (!scope) {
    exitWithError("missing_scope", "--scope is required in non-interactive mode (project, team, global)", flags);
  }
  if (args["api-key"] && scope !== "project") {
    exitWithError("invalid_flag", "--api-key is only valid with --scope project (cannot commit secrets)", flags);
  }
  if ((args.output || args["api-url"] || args["console-url"]) && scope !== "global") {
    exitWithError("invalid_flag", "--output, --api-url, and --console-url are only valid with --scope global", flags);
  }
  if (scope === "project") {
    const existing = readProjectConfig();
    const updates = {};
    if (args.tag)
      updates.tag = args.tag;
    if (args["api-key"]) {
      const config = resolveConfig();
      try {
        await validateApiKey(args["api-key"], config.apiUrl);
      } catch {
        exitWithError("invalid_api_key", "API key validation failed.", flags);
      }
      updates.apiKey = args["api-key"];
    }
    writeProjectConfig({ ...existing, ...updates });
    const projectDir = getProjectConfigPath();
    output({ scope: "project", ...updates, path: projectDir }, () => {
      const lines = [`${source_default.green("✓")} Configured (project scope)`];
      if (updates.tag)
        lines.push(`  Tag: ${updates.tag}`);
      if (updates.apiKey)
        lines.push("  API Key: updated");
      lines.push(`  Saved to ${source_default.dim(projectDir)}`);
      return lines.join(`
`);
    }, flags);
  } else if (scope === "team") {
    const gitRoot = findGitRoot();
    if (!gitRoot) {
      exitWithError("not_git_repo", "Not in a git repository. Team config requires a git repo.", flags);
    }
    const existing = readTeamConfig();
    if (existing && !args.tag && !args["api-key"]) {
      exitWithError("already_initialized", "Team config already exists. Use `supermemory config set` to update, or pass flags to override.", flags);
    }
    const updates = {};
    if (args.tag)
      updates.tag = args.tag;
    if (existing) {
      updateTeamConfig(updates);
    } else {
      initTeamConfig(updates);
    }
    const configPath = `${gitRoot}/.supermemory/config.json`;
    output({ scope: "team", ...updates, path: configPath }, () => {
      const lines = [`${source_default.green("✓")} Configured (team scope)`];
      if (updates.tag)
        lines.push(`  Tag: ${updates.tag}`);
      lines.push(`  Saved to ${source_default.dim(configPath)}`);
      return lines.join(`
`);
    }, flags);
  } else {
    const updates = {};
    if (args.output) {
      parseEnumArg(args.output, "output", [
        "auto",
        "json",
        "human"
      ]);
      updates.output = args.output;
    }
    if (args["api-url"])
      updates.apiUrl = args["api-url"];
    if (args["console-url"])
      updates.consoleUrl = args["console-url"];
    updateUserConfig(updates);
    output({ scope: "global", ...updates, path: "~/.supermemory/config.json" }, () => {
      const lines = [`${source_default.green("✓")} Configured (global scope)`];
      if (updates.output)
        lines.push(`  Output: ${updates.output}`);
      if (updates.apiUrl)
        lines.push(`  API URL: ${updates.apiUrl}`);
      if (updates.consoleUrl)
        lines.push(`  Console URL: ${updates.consoleUrl}`);
      lines.push(`  Saved to ${source_default.dim("~/.supermemory/config.json")}`);
      return lines.join(`
`);
    }, flags);
  }
}
function getProjectConfigPath() {
  return import_node_path5.join(getProjectDir(), "config.json");
}

// src/commands/keys.ts
var keysListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List all API keys for the current organization"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/keys");
    output(data, () => {
      const keys = (data.keys ?? []).filter((k2) => {
        if (!k2.metadata)
          return true;
        try {
          const meta = JSON.parse(k2.metadata);
          return meta.sm_type !== "agent_cli" && meta.sm_type !== "plugin_auth";
        } catch {
          return true;
        }
      });
      if (keys.length === 0) {
        return "  No API keys found.";
      }
      return formatTable(["PREFIX", "NAME", "TYPE", "PERMISSION", "CREATED"], keys.map((k2) => [
        k2.key ? maskApiKey(k2.key) : source_default.dim("--"),
        k2.name,
        k2.containerTag ? `scoped (${k2.containerTag})` : "full",
        k2.permission,
        new Date(k2.createdAt).toLocaleDateString()
      ]));
    }, flags);
  }
});
var keysCreateCommand = defineCliCommand({
  meta: {
    name: "create",
    description: "Create a new API key"
  },
  args: {
    name: {
      type: "string",
      description: "Label for the key",
      required: true
    },
    permission: {
      type: "string",
      description: "Permission level: read or write (default: write)"
    },
    tag: {
      type: "string",
      description: "Scope key to a container tag"
    },
    expires: {
      type: "string",
      description: "Expiration in days"
    }
  },
  async handler({ args, flags }) {
    const permission = parseEnumArg(args.permission, "permission", [
      "read",
      "write"
    ]) ?? "write";
    const expires = parseIntArg(args.expires, "expires", {
      min: 1
    });
    const body = {
      name: args.name,
      permission
    };
    if (args.tag)
      body.containerTag = args.tag;
    if (expires !== undefined)
      body.expiresInDays = expires;
    const { data } = await apiRequest("/v3/auth/agent-key", {
      method: "POST",
      body
    });
    output(data, () => {
      const lines = [];
      lines.push(`${source_default.green("✓")} Created API key ${source_default.bold(data.name)}`);
      lines.push("");
      lines.push(`  ${source_default.yellow("WARNING:")} This key will only be shown once. Copy it now.`);
      lines.push("");
      lines.push(`  ${source_default.bold(data.key)}`);
      lines.push("");
      lines.push(formatKeyValue([
        ["Name:", data.name],
        ["ID:", data.id],
        ["Permission:", data.permission],
        [
          "Scope:",
          data.containerTag ? `scoped (${data.containerTag})` : "full"
        ],
        [
          "Expires:",
          data.expiresAt ? new Date(data.expiresAt).toLocaleDateString() : "never"
        ]
      ]));
      return lines.join(`
`);
    }, flags);
  }
});
var keysRevokeCommand = defineCliCommand({
  meta: {
    name: "revoke",
    description: "Revoke an API key"
  },
  args: {
    id: {
      type: "positional",
      description: "Key ID to revoke",
      required: true
    },
    yes: {
      type: "boolean",
      description: "Skip confirmation (for scripts and agents)",
      default: false
    }
  },
  async handler({ args, flags }) {
    if (!args.yes) {
      const readline = await import("node:readline");
      const rl = readline.createInterface({
        input: process.stdin,
        output: process.stderr
      });
      const answer = await new Promise((resolve4) => {
        rl.question(`${source_default.yellow("⚠")} Revoke API key ${source_default.bold(args.id)}? This cannot be undone. [y/N] `, resolve4);
      });
      rl.close();
      if (answer.toLowerCase() !== "y") {
        exitWithError("cancelled", "Revocation cancelled.", flags, EXIT.SUCCESS);
      }
    }
    const { data } = await apiRequest(`/v3/auth/scoped-key/${args.id}`, {
      method: "DELETE"
    });
    output(data, () => `${source_default.green("✓")} Revoked API key ${source_default.dim(args.id)}`, flags);
  }
});
var keysToggleCommand = defineCliCommand({
  meta: {
    name: "toggle",
    description: "Enable or disable an API key"
  },
  args: {
    id: {
      type: "positional",
      description: "Key ID to toggle",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data } = await apiRequest(`/v3/auth/keys/${args.id}/toggle`, {
