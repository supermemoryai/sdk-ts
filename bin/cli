var VALID_PROVIDERS = [
  "google-drive",
  "notion",
  "onedrive",
  "gmail",
  "github",
  "web-crawler",
  "s3"
];
var connectorsListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List all connected integrations"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/connections/list", {
      method: "POST",
      body: {}
    });
    output(data, () => {
      const connections = Array.isArray(data) ? data : [];
      if (connections.length === 0) {
        return "  No connectors found.";
      }
      return formatTable(["PROVIDER", "EMAIL", "TAGS", "CONNECTED", "ID"], connections.map((c3) => [
        c3.provider,
        c3.email ?? source_default.dim("--"),
        c3.containerTags?.join(", ") || source_default.dim("--"),
        new Date(c3.createdAt).toLocaleDateString(),
        c3.id
      ]));
    }, flags);
  }
});
var connectorsConnectCommand = defineCliCommand({
  meta: {
    name: "connect",
    description: "Connect a new integration provider via browser OAuth"
  },
  args: {
    provider: {
      type: "positional",
      description: `Provider to connect (${VALID_PROVIDERS.join(", ")})`,
      required: true
    },
    tag: {
      type: "string",
      description: "Scope imported documents to a container tag"
    },
    "no-browser": {
      type: "boolean",
      description: "Print the URL instead of opening a browser",
      default: false
    }
  },
  async handler({ args, flags, config }) {
    parseEnumArg(args.provider, "provider", VALID_PROVIDERS);
    let url = `${config.consoleUrl}/connectors/${args.provider}/connect`;
    if (args.tag) {
      url += `?tag=${encodeURIComponent(args.tag)}`;
    }
    if (args["no-browser"]) {
      output({ url }, () => `  Open this URL to connect ${source_default.bold(args.provider)}:

  ${source_default.cyan(url)}`, flags);
    } else {
      await openBrowser(url);
      output({ url }, () => `${source_default.green("✓")} Opened browser to connect ${source_default.bold(args.provider)}

  ${source_default.dim(url)}`, flags);
    }
  }
});
var connectorsSyncCommand = defineCliCommand({
  meta: {
    name: "sync",
    description: "Trigger a sync for a connection"
  },
  args: {
    id: {
      type: "positional",
      description: "Connection ID to sync",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data: connection } = await apiRequest(`/v3/connections/${args.id}`);
    const { data } = await apiRequest(`/v3/connections/${connection.provider}/import`, {
      method: "POST",
      body: { connectionId: args.id }
    });
    output(data, () => `${source_default.green("✓")} Syncing... ${data.newDocuments != null ? `${data.newDocuments} new documents indexed` : "sync started"}`, flags);
  }
});
var connectorsHistoryCommand = defineCliCommand({
  meta: {
    name: "history",
    description: "Show sync history for a connection"
  },
  args: {
    id: {
      type: "positional",
      description: "Connection ID",
      required: true
    },
    limit: {
      type: "string",
      description: "Max results (default: 10)"
    }
  },
  async handler({ args, flags }) {
    const query = {};
    query.limit = parseIntArg(args.limit, "limit", { min: 1 }) ?? 10;
    const { data } = await apiRequest(`/v3/connections/${args.id}/sync-runs`, { query });
    output(data, () => {
      const history = data.history ?? [];
      if (history.length === 0) {
        return "  No sync history found.";
      }
      return formatTable(["TIMESTAMP", "STATUS", "DOCS ADDED", "DOCS UPDATED"], history.map((h2) => [
        formatRelativeTime(h2.timestamp),
        h2.status,
        String(h2.docsAdded ?? 0),
        String(h2.docsUpdated ?? 0)
      ]));
    }, flags);
  }
});
var connectorsDisconnectCommand = defineCliCommand({
  meta: {
    name: "disconnect",
    description: "Disconnect an integration"
  },
  args: {
    id: {
      type: "positional",
      description: "Connection ID to disconnect",
      required: true
    },
    yes: {
      type: "boolean",
      description: "Skip confirmation prompt",
      default: false
    }
  },
  async handler({ args, flags }) {
    if (!args.yes) {
      const readline = await import("node:readline");
      const rl = readline.createInterface({
        input: process.stdin,
        output: process.stderr
      });
      const answer = await new Promise((resolve4) => {
        rl.question(`${source_default.yellow("⚠")} Disconnect connection ${source_default.bold(args.id)}? This cannot be undone. [y/N] `, resolve4);
      });
      rl.close();
      if (answer.toLowerCase() !== "y") {
        exitWithError("cancelled", "Disconnect cancelled.", flags, EXIT.SUCCESS);
      }
    }
    const { data } = await apiRequest(`/v3/connections/${args.id}`, { method: "DELETE" });
    output(data, () => `${source_default.green("✓")} Disconnected connection ${source_default.dim(args.id)}`, flags);
  }
});
