  meta: {
    name: "plugins",
    description: "Manage plugin connections"
  },
  subCommands: {
    list: pluginsListCommand,
    connect: pluginsConnectCommand,
    revoke: pluginsRevokeCommand,
    status: pluginsStatusCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && ["list", "connect", "revoke", "status"].includes(sub))
      return;
    await runCommand(pluginsListCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: list, connect, revoke, status. Run supermemory plugins --help for details.")}
`);
  }
});

// src/commands/profile.ts
var profileCommand = defineCliCommand({
  meta: {
    name: "profile",
    description: "Get the user profile for a container tag"
  },
  args: {
    tag: {
      type: "positional",
      description: 'Container tag (e.g., "default" resolves to "sm_project_default")',
      required: false
    },
    query: {
      type: "string",
      description: "Also run a search within the profile"
    }
  },
  async handler({ args, flags, config, span }) {
    const tag = args.tag ?? config.tag;
    if (!tag) {
      throw new ValidationError("Container tag required. Use --tag");
    }
    const body = {
      containerTag: tag
    };
    if (args.query)
      body.q = args.query;
    const { data } = await apiRequest("/v4/profile", {
      method: "POST",
      body
    });
    span.setAttribute("staticCount", data.profile?.static?.length ?? 0);
    span.setAttribute("dynamicCount", data.profile?.dynamic?.length ?? 0);
    output(data, () => {
      const lines = [`  Profile for ${source_default.bold(tag)}`];
      lines.push("");
      const staticMems = data.profile?.static ?? [];
      const dynamicMems = data.profile?.dynamic ?? [];
      if (staticMems.length > 0) {
        lines.push(`  ${source_default.bold("Static Memories")} (long-term):`);
        for (const mem of staticMems) {
          lines.push(`    ${source_default.dim("•")} ${mem}`);
        }
        lines.push("");
      }
      if (dynamicMems.length > 0) {
        lines.push(`  ${source_default.bold("Dynamic Memories")} (recent):`);
        for (const mem of dynamicMems) {
          lines.push(`    ${source_default.dim("•")} ${mem}`);
        }
      }
      if (staticMems.length === 0 && dynamicMems.length === 0) {
        lines.push("  No memories found for this tag.");
      }
      return lines.join(`
`);
    }, flags);
  }
});

// src/commands/remember.ts
var rememberCommand = defineCliCommand({
  meta: {
    name: "remember",
    description: "Store a specific memory directly into a container tag"
  },
  args: {
    content: {
      type: "positional",
      description: "Memory content text",
      required: true
    },
    tag: {
      type: "string",
      description: "Container tag"
    },
    static: {
      type: "boolean",
      description: "Mark as permanent/static memory (long-term fact)",
      default: false
    },
    metadata: {
      type: "string",
      description: "JSON metadata to attach"
    }
  },
  async handler({ args, flags, config, span }) {
    const containerTag = args.tag ?? config.tag;
    if (!containerTag) {
      throw new ValidationError("Container tag required. Use --tag <name>");
    }
    const memory = {
      content: args.content
    };
    if (args.static)
      memory.isStatic = true;
    const metadata = parseJsonArg(args.metadata, "metadata");
    if (metadata)
      memory.metadata = metadata;
    const { data } = await apiRequest("/v4/memories", {
      method: "POST",
      body: {
        memories: [memory],
        containerTag
      }
    });
    const created = data.memories[0];
    span.setAttribute("memoryId", created?.id ?? "");
    output(data, () => {
      if (!created)
        return `${source_default.green("✓")} Memory stored`;
      const lines = [
        `${source_default.green("✓")} Remembered ${source_default.dim(created.id)}${created.isStatic ? source_default.dim(" (static)") : ""}`,
        `  Tag: ${containerTag}`
      ];
      return lines.join(`
`);
    }, flags);
  }
});

// src/commands/search.ts
var searchCommand = defineCliCommand({
  meta: {
    name: "search",
    description: "Search memories in a container tag"
  },
  args: {
    query: {
      type: "positional",
      description: "Search query text",
      required: true
    },
    tag: {
      type: "string",
      description: "Filter by container tag"
    },
    limit: {
      type: "string",
      description: "Max results (default: 10)"
    },
    threshold: {
      type: "string",
      description: "Similarity threshold 0-1 (default: 0.6)"
    },
    rerank: {
      type: "boolean",
      description: "Enable reranking for better accuracy",
      default: false
    },
    rewrite: {
      type: "boolean",
      description: "Rewrite query for better retrieval",
      default: false
    },
    mode: {
      type: "string",
      description: "Search mode: memories, hybrid, or documents (default: memories)"
    },
    include: {
      type: "string",
      description: "Comma-separated: summaries,documents,relatedMemories,forgottenMemories"
    },
    filter: {
      type: "string",
      description: "Metadata filter (JSON)"
    }
  },
  async handler({ args, flags, config, span }) {
    const tag = args.tag ?? config.tag;
    if (!tag) {
      throw new ValidationError("Container tag required. Use --tag <name>");
    }
    const body = {
      q: args.query
    };
    body.containerTag = tag;
    body.limit = parseIntArg(args.limit, "limit", {
      min: 1,
      max: 100
    });
    body.threshold = parseFloatArg(args.threshold, "threshold", { min: 0, max: 1 });
    if (args.rerank)
      body.rerank = true;
    if (args.rewrite)
      body.rewriteQuery = true;
    body.searchMode = parseEnumArg(args.mode, "mode", [
      "memories",
      "hybrid",
      "documents"
    ]);
    if (args.include) {
      const validFields = [
        "summaries",
        "documents",
        "relatedMemories",
        "forgottenMemories"
      ];
      const fields = args.include.split(",").map((s2) => s2.trim());
      const include = {};
      for (const f3 of fields) {
        if (validFields.includes(f3)) {
          include[f3] = true;
        }
      }
      body.include = include;
    }
    const filter = parseJsonArg(args.filter, "filter");
    if (filter)
      body.filters = filter;
    const start = Date.now();
    const { data } = await apiRequest("/v4/search", {
      method: "POST",
      body
    });
    const timing = Date.now() - start;
    span.setAttribute("resultCount", data.results?.length ?? 0);
    span.setAttribute("latencyMs", timing);
    output({ ...data, clientTiming: timing }, () => {
      const results = data.results ?? [];
      if (results.length === 0) {
        return "  No results found.";
      }
      const header = `  ${results.length} result${results.length === 1 ? "" : "s"} ${source_default.dim(`(${data.timing ?? timing}ms)`)}`;
      const items = results.map((r3) => {
        const lines = [];
        const displayText = r3.memory ?? r3.chunk ?? r3.id;
        lines.push(`"${displayText}"`);
        if (r3.memory && r3.chunk) {
          lines.push(`     ${source_default.dim("chunk:")} ${r3.chunk}`);
        }
        const meta = [`Score: ${source_default.bold(r3.similarity.toFixed(2))}`];
        if (r3.resultType === "chunk")
          meta.push("chunk");
        if (r3.version)
          meta.push(`v${r3.version}`);
        if (r3.updatedAt)
          meta.push(`Updated: ${formatRelativeTime(r3.updatedAt)}`);
        if (r3.documents?.length) {
          meta.push(`${r3.documents.length} doc${r3.documents.length > 1 ? "s" : ""}`);
        }
        lines.push(`     ${meta.join(` ${source_default.dim("·")} `)}`);
        return lines.join(`
`);
      });
      const numbered = items.map((item, i2) => `  ${source_default.dim(`${i2 + 1}.`)} ${item}`).join(`

`);
      return `${header}

${numbered}`;
    }, flags);
  }
});

// src/commands/status.ts
var VALID_PERIODS = ["24h", "7d", "30d", "all"];
var statusCommand = defineCliCommand({
  meta: {
    name: "status",
    description: "Show an overview dashboard of your organization"
  },
  args: {
    period: {
      type: "string",
      description: "Time period: 24h, 7d, 30d, all",
      default: "all"
    }
  },
  async handler({ args, flags }) {
    const period = VALID_PERIODS.includes(args.period) ? args.period : "all";
    const { data } = await apiRequest("/v3/analytics/memory", { query: { period } });
    const periodLabel = period === "all" ? "all time" : `last ${period}`;
    output(data, () => {
      const delta = (n2) => n2 != null && n2 > 0 ? source_default.green(` ↑${n2}`) : "";
      const lines = [];
      lines.push(`  ${source_default.bold("Overview")} ${source_default.dim(`(${periodLabel})`)}`);
      lines.push("");
      const pairs = [
        [
          "Documents:",
          `${data.totalMemories ?? 0}${delta(data.memoriesGrowth)}`
        ],
        [
          "Memories:",
          `${data.totalMemoryEntries ?? 0}${delta(data.memoryEntriesGrowth)}`
        ],
        [
          "Searches:",
          `${data.searchQueries ?? 0}${delta(data.searchGrowth)}`
        ],
        [
          "Connectors:",
          `${data.totalConnections ?? 0}${delta(data.connectionsGrowth)}`
        ],
        [
          "Container Tags:",
          `${data.totalContainerTags ?? 0}${delta(data.containerTagsGrowth)}`
        ]
      ];
      lines.push(formatKeyValue(pairs));
      lines.push("");
      lines.push(`  ${source_default.dim("Tip: supermemory status --period [24h|7d|30d|all]")}`);
      return lines.join(`
`);
    }, flags);
  }
});

// src/commands/tags.ts
var tagsListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List all container tags"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/container-tags/list");
    output(data, () => {
      const tags = Array.isArray(data) ? data : [];
      if (tags.length === 0) {
        return "  No container tags found.";
      }
      return formatTable(["TAG", "NAME", "DOCS", "MEMORIES", "LAST ACTIVITY"], tags.map((t2) => [
        t2.containerTag,
        t2.name ?? "",
        String(t2.documentCount ?? 0),
        String(t2.memoryCount ?? 0),
        t2.lastActivityAt ? new Date(t2.lastActivityAt).toLocaleDateString() : source_default.dim("never")
      ]));
    }, flags);
  }
});
var tagsInfoCommand = defineCliCommand({
  meta: {
    name: "info",
    description: "Show details about a container tag"
  },
  args: {
    tag: {
      type: "positional",
      description: "Container tag",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data } = await apiRequest(`/v3/container-tags/${encodeURIComponent(args.tag)}`);
    output(data, () => formatKeyValue([
      ["Tag:", data.containerTag],
      ["Name:", data.name ?? source_default.dim("(none)")],
      ["Documents:", String(data.documentCount ?? 0)],
      ["Memories:", String(data.memoryCount ?? 0)],
      [
        "Created:",
        data.createdAt ? new Date(data.createdAt).toLocaleDateString() : source_default.dim("unknown")
      ],
      [
        "Last Activity:",
        data.lastActivityAt ? new Date(data.lastActivityAt).toLocaleDateString() : source_default.dim("never")
      ],
      ["Context:", data.context ?? source_default.dim("(none)")]
    ]), flags);
  }
});
var tagsCreateCommand = defineCliCommand({
  meta: {
    name: "create",
    description: "Create a new container tag"
  },
  args: {
    tag: {
      type: "positional",
      description: "Container tag identifier",
      required: true
    },
    name: {
      type: "string",
      description: "Human-readable name for the tag"
    }
  },
  async handler({ args, flags }) {
    const body = { entityContext: null };
    if (args.name)
      body.name = args.name;
    const { data } = await apiRequest(`/v3/container-tags/${encodeURIComponent(args.tag)}`, {
      method: "PATCH",
      body
    });
    output(data, () => `${source_default.green("✓")} Created container tag ${source_default.bold(data.containerTag)}${data.name ? ` (${data.name})` : ""}`, flags);
  }
});
var tagsDeleteCommand = defineCliCommand({
  meta: {
    name: "delete",
    description: "Delete a container tag"
  },
  args: {
    tag: {
      type: "positional",
      description: "Container tag to delete",
      required: true
    },
    yes: {
      type: "boolean",
      description: "Skip confirmation prompt",
      default: false
    }
  },
  async handler({ args, flags }) {
    if (!args.yes) {
      const readline = await import("node:readline");
      const rl = readline.createInterface({
        input: process.stdin,
        output: process.stderr
      });
      const answer = await new Promise((resolve4) => {
        rl.question(`${source_default.yellow("⚠")} Delete container tag ${source_default.bold(args.tag)}? This cannot be undone. [y/N] `, resolve4);
      });
      rl.close();
      if (answer.toLowerCase() !== "y") {
        exitWithError("cancelled", "Deletion cancelled.", flags, EXIT.SUCCESS);
      }
    }
    const { data } = await apiRequest(`/v3/container-tags/${encodeURIComponent(args.tag)}`, { method: "DELETE" });
    output(data, () => `${source_default.green("✓")} Deleted container tag ${source_default.bold(args.tag)}`, flags);
  }
});
var tagsContextCommand = defineCliCommand({
  meta: {
    name: "context",
    description: "Get or set entity context for a container tag"
  },
  args: {
    tag: {
      type: "positional",
      description: "Container tag",
      required: true
    },
    set: {
      type: "string",
      description: "Set context to this text"
    },
    clear: {
      type: "boolean",
      description: "Clear the context",
      default: false
    }
  },
  async handler({ args, flags }) {
    const endpoint = `/v3/container-tags/${encodeURIComponent(args.tag)}`;
    if (args.clear) {
      const { data } = await apiRequest(endpoint, {
        method: "PATCH",
        body: { entityContext: null }
      });
      output(data, () => `${source_default.green("✓")} Cleared context for ${source_default.bold(args.tag)}`, flags);
    } else if (args.set) {
      const { data } = await apiRequest(endpoint, {
        method: "PATCH",
        body: { entityContext: args.set }
      });
      output(data, () => `${source_default.green("✓")} Updated context for ${source_default.bold(args.tag)}`, flags);
    } else {
      const { data } = await apiRequest(endpoint);
      output(data, () => {
        if (!data.entityContext) {
          return `  No context set for ${source_default.bold(args.tag)}.`;
        }
        return `  ${source_default.bold("Context for")} ${source_default.bold(args.tag)}:

  ${data.entityContext}`;
      }, flags);
    }
  }
});
var tagsMergeCommand = defineCliCommand({
  meta: {
    name: "merge",
    description: "Merge a source container tag into a target"
  },
  args: {
    source: {
      type: "positional",
      description: "Source container tag to merge from",
      required: true
    },
    into: {
      type: "string",
      description: "Target container tag to merge into",
      required: true
    }
  },
  async handler({ args, flags }) {
    if (!args.into) {
      exitWithError("validation_error", "--into <target> is required", flags);
    }
    const { data } = await apiRequest("/v3/container-tags/merge", {
      method: "POST",
      body: {
        sources: [args.source],
        target: args.into
      }
    });
    output(data, () => `${source_default.green("✓")} Merged ${source_default.bold(args.source)} into ${source_default.bold(args.into)}${data.merged != null ? ` (${data.merged} items)` : ""}`, flags);
  }
});
var tagsCommand = defineCommand({
  meta: {
    name: "tags",
    description: "Manage container tags"
  },
  subCommands: {
    list: tagsListCommand,
    info: tagsInfoCommand,
    create: tagsCreateCommand,
    delete: tagsDeleteCommand,
    context: tagsContextCommand,
    merge: tagsMergeCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && ["list", "info", "create", "delete", "context", "merge"].includes(sub))
      return;
    await runCommand(tagsListCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: list, info, create, delete, context, merge. Run supermemory tags --help for details.")}
`);
  }
});

// src/commands/team.ts
var teamListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List team members in the current organization"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/team/members");
    output(data, () => {
      const members = data.members ?? [];
      if (members.length === 0) {
        return "  No team members found.";
      }
      return formatTable(["NAME", "EMAIL", "ROLE", "JOINED"], members.map((m2) => [
        m2.name,
        m2.email,
        m2.role,
        new Date(m2.joinedAt).toLocaleDateString()
      ]));
    }, flags);
  }
});
var teamInviteCommand = defineCliCommand({
  meta: {
    name: "invite",
    description: "Invite a new member to the team"
  },
  args: {
    email: {
      type: "positional",
      description: "Email address to invite",
      required: true
    },
    role: {
      type: "string",
      description: "Role to assign: admin or member (default: member)"
    }
  },
  async handler({ args, flags }) {
    const role = parseEnumArg(args.role, "role", [
      "admin",
      "member"
    ]) ?? "member";
    const { data } = await apiRequest("/v3/auth/team/invite", {
      method: "POST",
      body: { email: args.email, role }
    });
    output(data, () => `${source_default.green("✓")} Invited ${source_default.bold(data.email)} as ${source_default.cyan(data.role)}`, flags);
  }
});
var teamRemoveCommand = defineCliCommand({
  meta: {
    name: "remove",
    description: "Remove a member from the team"
  },
  args: {
    "member-id": {
      type: "positional",
      description: "Member ID to remove",
      required: true
    },
    yes: {
      type: "boolean",
      description: "Skip confirmation (for scripts and agents)",
      default: false
    }
  },
  async handler({ args, flags }) {
    const memberId = args["member-id"];
    if (!args.yes) {
      const readline = await import("node:readline");
      const rl = readline.createInterface({
        input: process.stdin,
        output: process.stderr
      });
      const answer = await new Promise((resolve4) => {
        rl.question(`${source_default.yellow("?")} Remove team member ${source_default.bold(memberId)}? (y/N) `, resolve4);
      });
      rl.close();
      if (answer.toLowerCase() !== "y") {
        exitWithError("cancelled", "Remove cancelled", flags);
      }
    }
    const { data } = await apiRequest(`/v3/auth/team/members/${memberId}`, {
      method: "DELETE"
    });
    output(data, () => `${source_default.green("✓")} Removed team member ${source_default.dim(memberId)}`, flags);
  }
});
var teamRoleCommand = defineCliCommand({
  meta: {
    name: "role",
    description: "Change a team member's role"
  },
  args: {
    "member-id": {
      type: "positional",
      description: "Member ID to update",
      required: true
    },
    role: {
      type: "positional",
      description: "New role: admin or member",
      required: true
    }
  },
  async handler({ args, flags }) {
    const memberId = args["member-id"];
    parseEnumArg(args.role, "role", [
      "admin",
      "member"
    ]);
    const { data } = await apiRequest(`/v3/auth/team/members/${memberId}/role`, {
      method: "PUT",
      body: { role: args.role }
    });
    output(data, () => `${source_default.green("✓")} Updated ${source_default.dim(memberId)} role to ${source_default.cyan(data.role)}`, flags);
  }
});
var teamInvitationsCommand = defineCliCommand({
  meta: {
    name: "invitations",
    description: "List pending team invitations"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/team/invitations");
    output(data, () => {
      const invitations = data.invitations ?? [];
      if (invitations.length === 0) {
        return "  No pending invitations.";
      }
      return formatTable(["EMAIL", "ROLE", "INVITED AT", "STATUS"], invitations.map((inv) => [
        inv.email,
        inv.role,
        new Date(inv.invitedAt).toLocaleDateString(),
        inv.status === "pending" ? source_default.yellow(inv.status) : inv.status === "accepted" ? source_default.green(inv.status) : source_default.dim(inv.status)
      ]));
    }, flags);
  }
});
var teamCommand = defineCommand({
  meta: {
    name: "team",
    description: "Manage team members and invitations"
  },
  subCommands: {
    list: teamListCommand,
    invite: teamInviteCommand,
    remove: teamRemoveCommand,
    role: teamRoleCommand,
    invitations: teamInvitationsCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && ["list", "invite", "remove", "role", "invitations"].includes(sub))
      return;
    await runCommand(teamListCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: list, invite, remove, role, invitations. Run supermemory team --help for details.")}
`);
  }
});

// src/commands/update.ts
var updateCommand = defineCliCommand({
  meta: {
    name: "update",
    description: "Update an existing memory"
  },
  args: {
    id: {
      type: "positional",
      description: "Memory ID",
      required: true
    },
    content: {
      type: "positional",
      description: "New content text",
      required: true
    },
    tag: {
      type: "string",
      description: "Container tag"
    },
    metadata: {
      type: "string",
      description: "Updated metadata (JSON)"
    },
    reason: {
      type: "string",
      description: "Reason for update (creates version chain)"
    }
  },
  async handler({ args, flags, config }) {
    const tag = args.tag ?? config.tag;
    if (!tag) {
      throw new ValidationError("Container tag required. Use --tag <name>");
    }
    const body = {
      id: args.id,
      newContent: args.content
    };
    body.containerTag = tag;
    if (args.reason)
      body.reason = args.reason;
    const metadata = parseJsonArg(args.metadata, "metadata");
    if (metadata)
      body.metadata = metadata;
    const { data } = await apiRequest("/v4/memories", {
      method: "PATCH",
      body
    });
    output(data, () => {
      const lines = [
        `${source_default.green("✓")} Updated memory ${source_default.dim(data.id)}`
      ];
      if (data.version) {
        lines.push(`  Version: ${data.version}${data.parentId ? ` (parent: ${source_default.dim(data.parentId)})` : ""}`);
      }
      return lines.join(`
`);
    }, flags);
  }
});

