function findTeamConfigDir() {
  let dir = import_node_path2.resolve(process.cwd());
  const root = import_node_path2.sep;
  while (dir !== root) {
    const candidate = import_node_path2.join(dir, ".supermemory", "config.json");
    if (import_node_fs.existsSync(candidate)) {
      return import_node_path2.join(dir, ".supermemory");
    }
    if (import_node_fs.existsSync(import_node_path2.join(dir, ".git"))) {
      return null;
    }
    dir = import_node_path2.resolve(dir, "..");
  }
  return null;
}
function ensureDir(dir) {
  if (!import_node_fs.existsSync(dir)) {
    import_node_fs.mkdirSync(dir, { recursive: true });
  }
}
function readJsonFile(path) {
  try {
    if (!import_node_fs.existsSync(path))
      return null;
    const raw = import_node_fs.readFileSync(path, "utf-8");
    return JSON.parse(raw);
  } catch {
    return null;
  }
}
function writeJsonFile(path, data, secure = false) {
  ensureDir(import_node_path2.dirname(path));
  import_node_fs.writeFileSync(path, `${JSON.stringify(data, null, 2)}
`, "utf-8");
  if (secure) {
    import_node_fs.chmodSync(path, 384);
  }
}
function readUserConfig() {
  return readJsonFile(USER_CONFIG_PATH) ?? {};
}
function writeUserConfig(config) {
  writeJsonFile(USER_CONFIG_PATH, config);
}
function updateUserConfig(updates) {
  const current = readUserConfig();
  writeUserConfig({ ...current, ...updates });
}
function readCredentials() {
  return readJsonFile(CREDENTIALS_PATH);
}
function writeCredentials(creds) {
  writeJsonFile(CREDENTIALS_PATH, creds, true);
}
function deleteCredentials() {
  try {
    if (import_node_fs.existsSync(CREDENTIALS_PATH)) {
      import_node_fs.unlinkSync(CREDENTIALS_PATH);
    }
  } catch {}
}
function readTeamConfig() {
  const dir = findTeamConfigDir();
  if (!dir)
    return null;
  return readJsonFile(import_node_path2.join(dir, "config.json"));
}
function initTeamConfig(config) {
  const gitRoot = findGitRoot();
  if (!gitRoot) {
    throw new Error("Not in a git repository. Run this from a git repo.");
  }
  const teamDir = import_node_path2.join(gitRoot, ".supermemory");
  writeJsonFile(import_node_path2.join(teamDir, "config.json"), config);
}
function updateTeamConfig(updates) {
  const current = readTeamConfig();
  const merged = { ...current, ...updates };
  initTeamConfig(merged);
}
function findGitRoot() {
  try {
    return import_node_child_process.execSync("git rev-parse --show-toplevel", {
      encoding: "utf-8"
    }).trim();
  } catch {
    return null;
  }
}
function getDefaultTag() {
  return import_node_path2.basename(import_node_path2.resolve(process.cwd()));
}
function getAuthState() {
  const credentials = readCredentials();
  const teamConfig = readTeamConfig();
  const projectConfig = readProjectConfig();
  let apiKeyValue = null;
  let apiKeySource = null;
  if (process.env.SUPERMEMORY_API_KEY) {
    apiKeyValue = process.env.SUPERMEMORY_API_KEY;
    apiKeySource = "env";
  } else if (projectConfig?.apiKey) {
    apiKeyValue = projectConfig.apiKey;
    apiKeySource = "project";
  } else if (credentials?.apiKey) {
    apiKeyValue = credentials.apiKey;
    apiKeySource = "credentials";
  }
  let tagValue = null;
  let tagSource = null;
  if (process.env.SUPERMEMORY_TAG) {
    tagValue = process.env.SUPERMEMORY_TAG;
    tagSource = "env";
  } else if (teamConfig?.tag) {
    tagValue = teamConfig.tag;
    tagSource = "team";
  } else if (projectConfig?.tag) {
    tagValue = projectConfig.tag;
    tagSource = "project";
  }
  return {
    apiKey: {
      value: apiKeyValue,
      source: apiKeySource,
      masked: apiKeyValue ? maskApiKey(apiKeyValue) : null
    },
    tag: { value: tagValue, source: tagSource }
  };
}
function readProjectConfig() {
  const dir = getProjectDir();
  return readJsonFile(import_node_path2.join(dir, "config.json"));
}
function writeProjectConfig(config) {
  const dir = getProjectDir();
  writeJsonFile(import_node_path2.join(dir, "config.json"), config, !!config.apiKey);
}
function updateProjectConfig(updates) {
  const current = readProjectConfig();
  writeProjectConfig({ ...current, ...updates });
}
function readScopeCache(keyHash) {
  ensureDir(SCOPE_CACHE_DIR);
  const cache = readJsonFile(import_node_path2.join(SCOPE_CACHE_DIR, `${keyHash}.json`));
  if (!cache)
    return null;
  const cachedAt = new Date(cache.cachedAt).getTime();
  const now = Date.now();
  if (now - cachedAt > 24 * 60 * 60 * 1000)
    return null;
  return cache;
}
function writeScopeCache(keyHash, scope) {
  writeJsonFile(import_node_path2.join(SCOPE_CACHE_DIR, `${keyHash}.json`), scope);
}
function clearScopeCache() {
  try {
    if (!import_node_fs.existsSync(SCOPE_CACHE_DIR))
      return;
    for (const file of import_node_fs.readdirSync(SCOPE_CACHE_DIR)) {
      import_node_fs.unlinkSync(import_node_path2.join(SCOPE_CACHE_DIR, file));
    }
  } catch {}
}
function resolveConfig(flags) {
  const userConfig = readUserConfig();
  const credentials = readCredentials();
  const teamConfig = readTeamConfig();
  const projectConfig = readProjectConfig();
  const envApiKey = process.env.SUPERMEMORY_API_KEY;
  const storedApiKey = projectConfig?.apiKey ?? credentials?.apiKey;
  if (envApiKey && storedApiKey && envApiKey !== storedApiKey) {
    process.stderr.write("⚠ SUPERMEMORY_API_KEY env var is overriding stored credentials. Run `supermemory whoami` to verify.\n");
  }
  const apiKey = envApiKey ?? storedApiKey ?? null;
  const tag = flags?.tag ?? process.env.SUPERMEMORY_TAG ?? teamConfig?.tag ?? projectConfig?.tag ?? null;
  const apiUrl = process.env.SUPERMEMORY_API_URL ?? userConfig.apiUrl ?? "https://api.supermemory.ai";
  const consoleUrl = process.env.SUPERMEMORY_CONSOLE_URL ?? userConfig.consoleUrl ?? "https://console.supermemory.ai";
  const output2 = userConfig.output ?? "auto";
  return { apiKey, tag, apiUrl, consoleUrl, output: output2 };
}

// src/lib/errors.ts
class CliError extends Error {
  code;
  exitCode;
  hint;
  constructor(code, message, exitCode = EXIT.ERROR, hint) {
    super(message);
    this.code = code;
    this.exitCode = exitCode;
    this.hint = hint;
    this.name = "CliError";
  }
}

class AuthError extends CliError {
  constructor(message, hint) {
    super("not_authenticated", message, EXIT.AUTH_REQUIRED, hint ?? "Run `supermemory login` or check your API key");
  }
}

class PermissionError extends CliError {
  constructor(message, hint) {
    super("permission_denied", message, EXIT.PERMISSION_DENIED, hint ?? "This may require a full-access API key, not a scoped key");
  }
}

class NotFoundError extends CliError {
  constructor(message, hint) {
    super("not_found", message, EXIT.NOT_FOUND, hint ?? "Check the ID with `supermemory search <query>`");
  }
}

class ValidationError extends CliError {
  constructor(message, hint) {
    super("validation_error", message, EXIT.ERROR, hint);
  }
}
function httpErrorToCliError(status, body) {
  const rawMessage = body?.message ?? body?.error;
  const message = typeof rawMessage === "string" ? rawMessage : rawMessage ? JSON.stringify(rawMessage) : `HTTP ${status}`;
  switch (status) {
    case 401:
      return new AuthError(message);
    case 403:
      return new PermissionError(message);
    case 404:
      return new NotFoundError(message);
    case 429:
      return new CliError("rate_limited", message, EXIT.ERROR, "Rate limited. Wait a moment and try again");
    default:
      return new CliError("api_error", message, EXIT.ERROR);
  }
}

// src/lib/otel.ts
var import_api = __toESM(require_src(), 1);
var TRACER_NAME = "supermemory-cli";
var sdkInstance = null;
async function initOtel() {
  const endpoint = process.env.OTEL_EXPORTER_OTLP_ENDPOINT;
  if (!endpoint)
    return;
  try {
    const { NodeSDK } = await Promise.resolve().then(() => __toESM(require_src33(), 1));
    const { OTLPTraceExporter } = await Promise.resolve().then(() => __toESM(require_src24(), 1));
    const sdk = new NodeSDK({
      traceExporter: new OTLPTraceExporter({
        url: `${endpoint}/v1/traces`
      }),
      serviceName: process.env.OTEL_SERVICE_NAME ?? TRACER_NAME
    });
    sdk.start();
    sdkInstance = sdk;
  } catch {}
}
async function shutdownOtel() {
  if (sdkInstance) {
    try {
      await sdkInstance.shutdown();
    } catch {}
  }
}
function getTracer() {
  return import_api.trace.getTracer(TRACER_NAME);
}
async function withSpan(name, attrs, fn) {
  const tracer = getTracer();
  return tracer.startActiveSpan(name, { attributes: attrs }, async (span) => {
    try {
      const result = await fn(span);
      span.setStatus({ code: import_api.SpanStatusCode.OK });
      return result;
    } catch (err) {
      span.setStatus({
        code: import_api.SpanStatusCode.ERROR,
        message: String(err)
      });
      throw err;
    } finally {
      span.end();
    }
  });
}

// src/lib/api.ts
var cachedConfig = null;
function getConfig(flags) {
  if (!cachedConfig) {
    cachedConfig = resolveConfig(flags);
  }
  return cachedConfig;
}
async function apiRequest(path, options = {}) {
  const config = getConfig();
  if (!config.apiKey) {
    throw new AuthError("Not authenticated. Run `supermemory login` first or set SUPERMEMORY_API_KEY.");
  }
  const { method = "GET", body, headers = {}, query } = options;
  let url = `${config.apiUrl}${path}`;
  if (query) {
    const params = new URLSearchParams;
    for (const [key, value] of Object.entries(query)) {
      if (value !== undefined) {
        params.set(key, String(value));
      }
    }
    const qs = params.toString();
    if (qs)
      url += `?${qs}`;
  }
  const reqHeaders = {
    "x-api-key": config.apiKey,
    ...headers
  };
  if (body && !reqHeaders["content-type"]) {
    reqHeaders["content-type"] = "application/json";
  }
  return withSpan("supermemory.api_call", { method, path, url }, async (span) => {
    const start = Date.now();
    const response = await fetch(url, {
      method,
      headers: reqHeaders,
      body: body ? JSON.stringify(body) : undefined
    });
    const latency = Date.now() - start;
    span.setAttribute("statusCode", response.status);
    span.setAttribute("latencyMs", latency);
    let data;
    const contentType = response.headers.get("content-type") ?? "";
    if (contentType.includes("application/json")) {
      data = await response.json();
    } else {
      data = await response.text();
    }
    if (!response.ok) {
      throw httpErrorToCliError(response.status, typeof data === "object" && data !== null ? data : null);
    }
    return { ok: true, status: response.status, data };
  });
}
async function apiRequestFormData(path, formData) {
  const config = getConfig();
  if (!config.apiKey) {
    throw new AuthError("Not authenticated. Run `supermemory login` first or set SUPERMEMORY_API_KEY.");
  }
  const apiKey = config.apiKey;
  const url = `${config.apiUrl}${path}`;
  return withSpan("supermemory.api_call", { method: "POST", path, url }, async (span) => {
    const start = Date.now();
    const response = await fetch(url, {
      method: "POST",
      headers: {
        "x-api-key": apiKey
      },
      body: formData
    });
    const latency = Date.now() - start;
    span.setAttribute("statusCode", response.status);
    span.setAttribute("latencyMs", latency);
    let data;
    const contentType = response.headers.get("content-type") ?? "";
    if (contentType.includes("application/json")) {
      data = await response.json();
    } else {
      data = await response.text();
    }
    if (!response.ok) {
      throw httpErrorToCliError(response.status, typeof data === "object" && data !== null ? data : null);
    }
    return { ok: true, status: response.status, data };
  });
}
async function validateApiKey(apiKey, apiUrl) {
  const response = await fetch(`${apiUrl}/v3/session`, {
    headers: { "x-api-key": apiKey }
  });
  if (!response.ok) {
    if (response.status === 401) {
      throw new AuthError("Invalid API key.");
    }
    throw httpErrorToCliError(response.status, null);
  }
  const data = await response.json();
  return {
    user: data.user ?? { email: "unknown", name: "Unknown" },
    org: data.org ?? { id: "", name: "", slug: "" },
    plan: data.plan ?? "free",
    scope: data.scope ?? { type: "full", permission: "write" }
  };
}

// src/lib/command.ts
var noopSpan = {
  setAttribute: () => noopSpan,
  setAttributes: () => noopSpan,
  addEvent: () => noopSpan,
  setStatus: () => noopSpan,
  updateName: () => noopSpan,
  end: () => {},
  isRecording: () => false,
  recordException: () => {},
  spanContext: () => ({ traceId: "", spanId: "", traceFlags: 0 })
};
function defineCliCommand(options) {
  const allArgs = {
    ...options.args ?? {},
    json: {
      type: "boolean",
      description: "Force JSON output",
      default: false
    }
  };
  return defineCommand({
    meta: options.meta,
    args: allArgs,
    async run({ args }) {
      const flags = { json: args.json };
      const config = getConfig({
        tag: args.tag
      });
      const runHandler = async (span) => {
        await options.handler({
          args,
          flags,
          config,
          span
        });
      };
      if (options.noSpan) {
        await runHandler(noopSpan);
      } else {
        await withSpan("supermemory.command", { commandName: options.meta.name }, runHandler);
      }
    }
  });
}

// src/lib/validators.ts
function parseIntArg(value, name, opts) {
  if (value === undefined)
    return;
  const n2 = Number.parseInt(value, 10);
  if (Number.isNaN(n2)) {
    throw new ValidationError(`--${name} must be an integer, got "${value}"`);
  }
  if (opts?.min !== undefined && n2 < opts.min) {
    throw new ValidationError(`--${name} must be at least ${opts.min}, got ${n2}`);
  }
  if (opts?.max !== undefined && n2 > opts.max) {
    throw new ValidationError(`--${name} must be at most ${opts.max}, got ${n2}`);
  }
  return n2;
}
function parseFloatArg(value, name, opts) {
  if (value === undefined)
    return;
  const n2 = Number.parseFloat(value);
  if (Number.isNaN(n2)) {
    throw new ValidationError(`--${name} must be a number, got "${value}"`);
  }
  if (opts?.min !== undefined && n2 < opts.min) {
    throw new ValidationError(`--${name} must be at least ${opts.min}, got ${n2}`);
  }
  if (opts?.max !== undefined && n2 > opts.max) {
    throw new ValidationError(`--${name} must be at most ${opts.max}, got ${n2}`);
  }
  return n2;
}
function parseEnumArg(value, name, validValues) {
  if (value === undefined)
    return;
  if (!validValues.includes(value)) {
    throw new ValidationError(`--${name} must be one of: ${validValues.join(", ")}. Got "${value}"`);
  }
  return value;
}
function parseJsonArg(value, name) {
  if (value === undefined)
    return;
  try {
    return JSON.parse(value);
  } catch {
    throw new ValidationError(`--${name} must be valid JSON`);
  }
}

// src/commands/add.ts
var addCommand = defineCliCommand({
  meta: {
    name: "add",
    description: "Ingest content and extract memories into a container tag"
  },
  args: {
    content: {
      type: "positional",
      description: "Text string, file path, or URL",
      required: false
    },
    tag: {
      type: "string",
      description: "Container tag"
    },
    stdin: {
      type: "boolean",
      description: "Read content from stdin",
      default: false
    },
    title: {
      type: "string",
      description: "Document title"
    },
    metadata: {
      type: "string",
      description: "JSON metadata to attach"
    },
    id: {
      type: "string",
      description: "Custom document ID (for idempotency)"
    },
    batch: {
      type: "boolean",
      description: "Read JSON array from stdin (batch mode)",
      default: false
    }
  },
  async handler({ args, flags, config, span }) {
    const tag = args.tag ?? config.tag;
    if (!tag) {
      throw new ValidationError("Container tag required. Use --tag <name>");
    }
    if (args.stdin || args.batch) {
      const stdinContent = await readStdin();
      if (!stdinContent) {
        exitWithError("validation_error", "No input received from stdin", flags);
      }
      if (args.batch) {
        return handleBatch(stdinContent, tag, flags);
      }
      return handleTextAdd(stdinContent, tag, args, flags, span);
    }
    if (!args.content) {
      exitWithError("validation_error", "Content argument required. Usage: supermemory add <content|file|url>", flags);
    }
    const content = args.content;
    if (content.startsWith("http://") || content.startsWith("https://")) {
      span.setAttribute("contentType", "url");
      return handleUrlAdd(content, tag, args, flags);
    }
    const filePath = import_node_path3.resolve(content);
    if (import_node_fs2.existsSync(filePath)) {
      span.setAttribute("contentType", "file");
      return handleFileAdd(filePath, tag, args, flags);
    }
    span.setAttribute("contentType", "text");
    return handleTextAdd(content, tag, args, flags, span);
  }
});
async function readStdin() {
  if (isInputInteractive())
    return "";
  const chunks = [];
  for await (const chunk of process.stdin) {
    chunks.push(chunk);
  }
  return Buffer.concat(chunks).toString("utf-8").trim();
}
async function handleTextAdd(content, tag, args, flags, span) {
  const body = { content };
  body.containerTag = tag;
  if (args.title)
    body.title = args.title;
  if (args.id)
    body.customId = args.id;
  const metadata = parseJsonArg(args.metadata, "metadata");
  if (metadata)
    body.metadata = metadata;
  const { data } = await apiRequest("/v3/documents", {
    method: "POST",
    body
  });
  span?.setAttribute("documentId", data.id ?? "");
  output(data, () => {
    const lines = [
      `${source_default.green("✓")} Added document ${source_default.dim(data.id)} (${data.status ?? "queued"})`
    ];
    if (data.containerTag || tag) {
      lines.push(`  Tag: ${data.containerTag ?? tag}`);
    }
    return lines.join(`
`);
  }, flags);
}
async function handleUrlAdd(url, tag, args, flags) {
  const body = { content: url };
  body.containerTag = tag;
  if (args.title)
    body.title = args.title;
  if (args.id)
    body.customId = args.id;
  const metadata = parseJsonArg(args.metadata, "metadata");
  if (metadata)
    body.metadata = metadata;
  const { data } = await apiRequest("/v3/documents", {
    method: "POST",
    body
  });
  output(data, () => {
    const lines = [
      `${source_default.green("✓")} Added URL ${source_default.dim(url)} → ${source_default.dim(data.id)} (${data.status ?? "queued"})`
    ];
    if (data.containerTag || tag) {
      lines.push(`  Tag: ${data.containerTag ?? tag}`);
    }
    return lines.join(`
`);
  }, flags);
}
async function handleFileAdd(filePath, tag, args, flags) {
  const fileBuffer = import_node_fs2.readFileSync(filePath);
  const fileName = import_node_path3.basename(filePath);
  const blob = new Blob([fileBuffer]);
  const formData = new FormData;
  formData.append("file", blob, fileName);
  formData.append("containerTag", tag);
  if (args.title)
    formData.append("title", args.title);
  if (args.id)
    formData.append("customId", args.id);
  if (args.metadata) {
    parseJsonArg(args.metadata, "metadata");
    formData.append("metadata", args.metadata);
  }
  const { data } = await apiRequestFormData("/v3/documents/file", formData);
  output(data, () => {
    const lines = [
      `${source_default.green("✓")} Uploaded ${source_default.dim(fileName)} → ${source_default.dim(data.id)} (${data.status ?? "queued"})`
    ];
    if (data.containerTag || tag) {
      lines.push(`  Tag: ${data.containerTag ?? tag}`);
    }
    return lines.join(`
`);
  }, flags);
}
async function handleBatch(stdinContent, tag, flags) {
  let items;
  try {
    items = JSON.parse(stdinContent);
    if (!Array.isArray(items))
      throw new Error("Expected JSON array");
  } catch {
    return exitWithError("validation_error", "Invalid JSON array from stdin for batch mode", flags);
  }
  const results = [];
  for (const item of items) {
    const body = { content: item.content };
    body.containerTag = item.tag ?? tag;
    if (item.title)
      body.title = item.title;
    if (item.metadata)
      body.metadata = item.metadata;
    if (item.id)
      body.customId = item.id;
    const { data } = await apiRequest("/v3/documents", { method: "POST", body });
    results.push(data);
  }
  output({ results, total: results.length }, () => `${source_default.green("✓")} Added ${results.length} documents in batch`, flags);
}

// src/lib/browser.ts
var import_node_http = require("node:http");
var import_node_os3 = require("node:os");
var import_node_path4 = require("node:path");
async function openBrowser(url) {
  const { exec } = await import("node:child_process");
  const os2 = import_node_os3.platform();
  let cmd;
  if (os2 === "darwin") {
    cmd = `open "${url}"`;
  } else if (os2 === "win32") {
    cmd = `start "" "${url}"`;
  } else {
    cmd = `xdg-open "${url}"`;
  }
  return new Promise((res, rej) => {
    exec(cmd, (err) => {
      if (err)
        rej(err);
      else
        res();
    });
  });
}
function getDeviceInfo() {
  return {
    hostname: import_node_os3.hostname(),
    os: `${import_node_os3.platform()}-${import_node_os3.arch()}`,
    cwd: import_node_path4.resolve(process.cwd()),
    cliVersion: "0.1.0"
  };
}
function startCallbackServer() {
  return new Promise((resolveServer, rejectServer) => {
    let resolveCallback;
    let rejectCallback;
    const callbackPromise = new Promise((res, rej) => {
      resolveCallback = res;
      rejectCallback = rej;
    });
    let timeoutId;
    const server = import_node_http.createServer((req, res) => {
      const url = new URL(req.url ?? "/", "http://localhost");
      if (url.pathname === "/callback") {
        const apiKey = url.searchParams.get("apikey");
        if (apiKey) {
          res.writeHead(200, { "Content-Type": "text/html" });
          res.end(`
<!DOCTYPE html>
<html>
<head><title>Supermemory CLI</title></head>
<body style="font-family: system-ui; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0;">
  <div style="text-align: center;">
    <h1>Authentication Successful</h1>
    <p>You can close this window and return to the terminal.</p>
  </div>
</body>
</html>`);
          clearTimeout(timeoutId);
          resolveCallback(apiKey);
        } else {
          res.writeHead(400, { "Content-Type": "text/html" });
          res.end(`
<!DOCTYPE html>
<html>
<head><title>Supermemory CLI</title></head>
<body style="font-family: system-ui; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0;">
  <div style="text-align: center;">
    <h1>Authentication Failed</h1>
    <p>No API key was returned. Please try again.</p>
  </div>
</body>
</html>`);
          clearTimeout(timeoutId);
          rejectCallback(new Error("No API key received from callback"));
        }
      } else {
        res.writeHead(404);
        res.end("Not found");
      }
    });
    server.listen(0, "127.0.0.1", () => {
      const addr = server.address();
      if (!addr || typeof addr === "string") {
        rejectServer(new Error("Failed to start callback server"));
        return;
      }
      resolveServer({
        port: addr.port,
        waitForCallback: () => callbackPromise,
        close: () => server.close()
      });
    });
    timeoutId = setTimeout(() => {
      rejectCallback(new Error("Authentication timed out"));
      server.close();
    }, 60000);
  });
}

// src/commands/auth.ts
function extractOrgIdFromKey(apiKey) {
  const parts = apiKey.split("_");
  return parts.length >= 3 ? parts[1] : undefined;
}
var loginCommand = defineCommand({
  meta: {
    name: "login",
    description: "Authenticate with Supermemory"
  },
  args: {
    "api-key": {
      type: "string",
      description: "Use an API key directly (skips browser flow)"
    },
    "no-browser": {
      type: "boolean",
      description: "Show login URL instead of opening browser",
      default: false
    },
    json: {
      type: "boolean",
      description: "Force JSON output",
      default: false
    }
  },
  async run({ args }) {
    const flags = { json: args.json };
    const config = resolveConfig();
    await withSpan("supermemory.command", { commandName: "login" }, async () => {
      const apiKey = args["api-key"];
      if (apiKey) {
        return loginWithApiKey(apiKey, config.apiUrl, flags);
      }
      return loginWithBrowser(config.consoleUrl, config.apiUrl, args["no-browser"], flags);
    });
  }
});
async function loginWithApiKey(apiKey, apiUrl, flags) {
  try {
    const session = await validateApiKey(apiKey, apiUrl);
    writeCredentials({
      apiKey,
      method: "api-key",
      orgId: extractOrgIdFromKey(apiKey) ?? session.org?.id,
      createdAt: new Date().toISOString()
    });
    output({
      user: session.user,
      org: session.org,
      method: "api-key"
    }, () => {
      const lines = [
        `${source_default.green("✓")} Logged in as ${source_default.bold(session.user.email)}`
      ];
      if (session.org) {
        lines.push(`${source_default.green("✓")} Organization: ${session.org.name} (${session.org.slug})`);
      }
      lines.push(`${source_default.green("✓")} Credentials saved to ~/.supermemory/credentials.json`);
      return lines.join(`
`);
    }, flags);
  } catch (err) {
    exitWithError("invalid_api_key", err instanceof Error ? err.message : "Invalid API key", flags, EXIT.AUTH_REQUIRED);
  }
}
async function loginWithBrowser(consoleUrl, apiUrl, noBrowser, flags) {
  const device = getDeviceInfo();
  try {
    const server = await startCallbackServer();
    const callbackUrl = `http://localhost:${server.port}/callback`;
    const params = new URLSearchParams({
      callback: callbackUrl,
      hostname: device.hostname,
      os: device.os,
      cwd: device.cwd,
      cli_version: device.cliVersion
    });
    const authUrl = `${consoleUrl}/auth/agent-connect?${params.toString()}`;
    if (noBrowser) {
      info("Open this URL in your browser to authenticate:", flags);
    } else {
      info("Opening browser for authentication...", flags);
      try {
        await openBrowser(authUrl);
      } catch {
        info("Could not open browser automatically.", flags);
      }
    }
    info(`  ${authUrl}`, flags);
    info("Waiting for authentication...", flags);
    const apiKey = await server.waitForCallback();
    server.close();
    const session = await validateApiKey(apiKey, apiUrl);
    writeCredentials({
      apiKey,
      method: "browser",
      orgId: extractOrgIdFromKey(apiKey) ?? session.org?.id,
      createdAt: new Date().toISOString()
    });
    output({
      user: session.user,
      org: session.org,
      method: "browser"
    }, () => {
      const lines = [
        "",
        `${source_default.green("✓")} Logged in as ${source_default.bold(session.user.email)}`
      ];
      if (session.org) {
        lines.push(`${source_default.green("✓")} Organization: ${session.org.name}`);
      }
      lines.push(`${source_default.green("✓")} Credentials saved to ~/.supermemory/credentials.json`);
      return lines.join(`
`);
    }, flags);
  } catch (err) {
    exitWithError("auth_failed", err instanceof Error ? err.message : "Authentication failed", flags, EXIT.AUTH_REQUIRED);
  }
}
var logoutCommand = defineCommand({
  meta: {
    name: "logout",
    description: "Remove stored credentials"
  },
  args: {
    json: {
      type: "boolean",
      description: "Force JSON output",
      default: false
    }
  },
  async run({ args }) {
    const flags = { json: args.json };
    deleteCredentials();
    clearScopeCache();
    output({ loggedOut: true }, () => `${source_default.green("✓")} Logged out. Credentials removed.`, flags);
  }
});
var whoamiCommand = defineCommand({
  meta: {
    name: "whoami",
    description: "Show current authentication status"
  },
  args: {
    json: {
      type: "boolean",
      description: "Force JSON output",
      default: false
    }
  },
  async run({ args }) {
    const flags = { json: args.json };
    const config = resolveConfig();
    if (!config.apiKey) {
      exitWithError("not_authenticated", "Not authenticated. Run `supermemory login` first.", flags, EXIT.AUTH_REQUIRED);
      return;
    }
    const apiKey = config.apiKey;
    await withSpan("supermemory.command", { commandName: "whoami" }, async () => {
      try {
        const session = await validateApiKey(apiKey, config.apiUrl);
        output({
          user: session.user,
          org: session.org,
          plan: session.plan,
          auth: {
            method: "api-key",
            keyPrefix: maskApiKey(apiKey)
          },
          ...session.scope.type === "scoped" ? {
            scope: {
              type: "scoped",
              tag: session.scope.tag,
              rateLimit: session.scope.rateLimit,
              expires: session.scope.expires,
              permission: session.scope.permission
            }
          } : { scope: { type: "full" } }
        }, (data) => {
          const d2 = data;
          const lines = [
            ["User:", `${d2.user.email}`],
            ["Org:", `${d2.org.name} (${d2.org.id})`],
            ["Plan:", d2.plan],
            ["Auth:", `${d2.auth.method} (${d2.auth.keyPrefix})`]
          ];
          if (d2.scope.type === "scoped") {
            lines.push(["Scope:", `scoped to ${d2.scope.tag} (enforced)`]);
            if (d2.scope.permission)
              lines.push(["Permission:", d2.scope.permission]);
            if (d2.scope.rateLimit)
              lines.push(["Rate Limit:", `${d2.scope.rateLimit} req/min`]);
            if (d2.scope.expires)
              lines.push(["Expires:", d2.scope.expires]);
          }
          return formatKeyValue(lines);
        }, flags);
      } catch (err) {
        exitWithError("not_authenticated", err instanceof Error ? err.message : "Authentication failed", flags, EXIT.AUTH_REQUIRED);
      }
    });
  }
});

// src/commands/billing.ts
var billingShowCommand = defineCliCommand({
  meta: {
    name: "show",
    description: "Show current billing plan and usage summary"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/billing");
    output(data, () => {
      const usage = data.usage ?? {
        tokens: { used: 0, limit: 0 },
        queries: { used: 0, limit: 0 }
      };
      const pairs = [
        ["Plan:", source_default.cyan(data.plan ?? "unknown")]
      ];
      if (data.billingEmail) {
        pairs.push(["Billing Email:", data.billingEmail]);
      }
      pairs.push([
        "Tokens:",
        usage.tokens.limit > 0 ? `${usage.tokens.used.toLocaleString()} / ${usage.tokens.limit.toLocaleString()}  ${formatProgressBar(usage.tokens.used, usage.tokens.limit)}` : `${usage.tokens.used.toLocaleString()}`
      ]);
      pairs.push([
        "Queries:",
        usage.queries.limit > 0 ? `${usage.queries.used.toLocaleString()} / ${usage.queries.limit.toLocaleString()}  ${formatProgressBar(usage.queries.used, usage.queries.limit)}` : `${usage.queries.used.toLocaleString()}`
      ]);
      if (data.resetDate) {
        pairs.push([
          "Resets On:",
          new Date(data.resetDate).toLocaleDateString()
        ]);
      }
      return formatKeyValue(pairs);
    }, flags);
  }
});
var billingUsageCommand = defineCliCommand({
  meta: {
    name: "usage",
    description: "Show detailed usage breakdown"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/billing/usage");
    output(data, () => {
      const items = data.items ?? [];
      if (items.length === 0) {
        return "  No usage data available.";
      }
      const lines = [];
      if (data.periodStart && data.periodEnd) {
        lines.push(`  Period: ${source_default.dim(`${new Date(data.periodStart).toLocaleDateString()} - ${new Date(data.periodEnd).toLocaleDateString()}`)}`);
        lines.push("");
      }
      const rows = items.map((item) => [
        item.name,
        item.used.toLocaleString(),
        item.limit > 0 ? item.limit.toLocaleString() : source_default.dim("unlimited"),
        item.unit,
        item.limit > 0 ? formatProgressBar(item.used, item.limit) : source_default.dim("-")
      ]);
      lines.push(formatTable(["METRIC", "USED", "LIMIT", "UNIT", "USAGE"], rows));
      return lines.join(`
`);
    }, flags);
  }
});
var billingInvoicesCommand = defineCliCommand({
  meta: {
    name: "invoices",
    description: "List billing invoices"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/billing/invoices");
    output(data, () => {
      const invoices = data.invoices ?? [];
      if (invoices.length === 0) {
        return "  No invoices found.";
      }
      const rows = invoices.map((inv) => [
        new Date(inv.date).toLocaleDateString(),
        `${(inv.amount / 100).toFixed(2)} ${(inv.currency ?? "USD").toUpperCase()}`,
        inv.status === "paid" ? source_default.green(inv.status) : inv.status === "open" ? source_default.yellow(inv.status) : source_default.dim(inv.status),
        source_default.dim(inv.id)
      ]);
      return formatTable(["DATE", "AMOUNT", "STATUS", "ID"], rows);
    }, flags);
  }
});
var billingCommand = defineCommand({
  meta: {
    name: "billing",
    description: "View billing, usage, and invoices"
  },
  subCommands: {
    show: billingShowCommand,
    usage: billingUsageCommand,
    invoices: billingInvoicesCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && ["show", "usage", "invoices"].includes(sub))
      return;
    await runCommand(billingShowCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: show, usage, invoices. Run supermemory billing --help for details.")}
`);
  }
});

// src/commands/config.ts
var KEY_SCOPE_MATRIX = {
  apiKey: {
    project: true,
    team: "API keys should not be committed to git. Use --scope project instead.",
    global: "Use 'supermemory login' to authenticate globally."
  },
  tag: {
    project: true,
    team: true,
    global: "Tag is project/team scoped. Use --scope project or --scope team."
  },
  output: {
    project: "Output format is global only. Use --scope global.",
    team: "Output format is global only. Use --scope global.",
    global: true
  },
  apiUrl: {
    project: "API URL is global only. Use --scope global.",
    team: "API URL is global only. Use --scope global.",
    global: true
  },
  consoleUrl: {
    project: "Console URL is global only. Use --scope global.",
    team: "Console URL is global only. Use --scope global.",
    global: true
  }
};
var VALID_SET_KEYS = Object.keys(KEY_SCOPE_MATRIX);
var VALID_SCOPES = ["project", "team", "global"];
var configSetCommand = defineCliCommand({
  meta: {
    name: "set",
    description: "Set a configuration value"
  },
  noSpan: true,
  args: {
    key: {
      type: "positional",
      description: `Config key (${VALID_SET_KEYS.join(", ")})`,
      required: true
    },
    value: {
      type: "positional",
      description: "Config value",
      required: true
    },
    scope: {
      type: "string",
      description: "Config scope: project, team, or global",
      default: "project"
    }
  },
  async handler({ args, flags }) {
    const key = args.key;
    const value = args.value;
    const scope = parseEnumArg(args.scope, "scope", VALID_SCOPES);
    if (!scope) {
      throw new Error(`Invalid scope. Valid scopes: ${VALID_SCOPES.join(", ")}`);
    }
    const matrix = KEY_SCOPE_MATRIX[key];
    if (!matrix) {
      throw new Error(`Unknown config key "${key}". Valid keys: ${VALID_SET_KEYS.join(", ")}`);
    }
    const scopeRule = matrix[scope];
    if (typeof scopeRule === "string") {
      throw new Error(scopeRule);
    }
    if (!scopeRule) {
      throw new Error(`Cannot set "${key}" in ${scope} scope.`);
    }
    if (key === "output") {
      parseEnumArg(value, "output", ["auto", "json", "human"]);
    }
    const fieldName = scope === "global" && matrix.globalField ? matrix.globalField : key;
    if (scope === "project") {
      updateProjectConfig({ [fieldName]: value });
    } else if (scope === "team") {
      updateTeamConfig({ [fieldName]: value });
    } else {
      updateUserConfig({ [fieldName]: value });
    }
    output({ key, value, scope }, () => `${source_default.green("✓")} Set ${key} = ${value} (${scope} scope)`, flags);
  }
});
var VALID_RESOLVED_KEYS = [
  "apiKey",
  "tag",
  "apiUrl",
  "consoleUrl",
  "output"
];
var configGetCommand = defineCliCommand({
  meta: {
    name: "get",
    description: "Get a resolved configuration value"
  },
  noSpan: true,
  args: {
    key: {
      type: "positional",
      description: `Config key (${VALID_RESOLVED_KEYS.join(", ")})`,
      required: true
    }
  },
  async handler({ args, flags }) {
    parseEnumArg(args.key, "key", VALID_RESOLVED_KEYS);
    const resolved = resolveConfig();
    const value = resolved[args.key];
    const displayValue = args.key === "apiKey" && typeof value === "string" ? maskApiKey(value) : String(value ?? "(none)");
    output({ key: args.key, value }, () => displayValue, flags);
  }
});
var configCommand = defineCommand({
  meta: {
    name: "config",
    description: "View and manage CLI configuration"
  },
  args: {
    json: {
      type: "boolean",
      default: false,
      description: "Force JSON output"
    }
  },
  subCommands: {
    set: configSetCommand,
    get: configGetCommand
  },
  async run({ rawArgs, args }) {
    const firstArg = rawArgs.find((a2) => !a2.startsWith("-"));
    if (firstArg === "set" || firstArg === "get")
      return;
    const flags = { json: args.json };
    const userConfig = readUserConfig();
    const teamConfig = readTeamConfig();
    const projectConfig = readProjectConfig();
    const credentials = readCredentials();
    const resolved = resolveConfig();
    const data = {
      resolved: {
        apiKey: resolved.apiKey ? maskApiKey(resolved.apiKey) : null,
        tag: resolved.tag,
        apiUrl: resolved.apiUrl,
        consoleUrl: resolved.consoleUrl,
        output: resolved.output
      },
      scopes: {
        user: {
          path: getUserDir(),
          config: userConfig,
          hasCredentials: !!credentials
        },
        team: teamConfig ? { config: teamConfig } : null,
        project: projectConfig ?? null
      }
    };
    output(data, () => {
      const lines = [
        `  ${source_default.bold("Resolved Configuration")} (highest precedence wins)`,
        ""
      ];
      const pairs = [
        [
          "API Key:",
          resolved.apiKey ? maskApiKey(resolved.apiKey) : source_default.dim("(none)")
        ],
        ["Tag:", resolved.tag ?? source_default.dim("(none)")],
        ["API URL:", resolved.apiUrl],
        ["Console URL:", resolved.consoleUrl],
        ["Output:", resolved.output]
      ];
      lines.push(formatKeyValue(pairs));
      lines.push("");
      lines.push(`  ${source_default.bold("User Scope")} ${source_default.dim("(~/.supermemory/)")}`);
      if (Object.keys(userConfig).length > 0) {
        for (const [key, value] of Object.entries(userConfig)) {
          lines.push(`    ${source_default.dim(key)}: ${value}`);
        }
      } else {
        lines.push(`    ${source_default.dim("(empty)")}`);
      }
      lines.push(`    Credentials: ${credentials ? source_default.green("stored") : source_default.dim("none")}`);
      lines.push("");
      lines.push(`  ${source_default.bold("Team Scope")} ${source_default.dim("(.supermemory/ in repo)")}`);
      if (teamConfig) {
        for (const [key, value] of Object.entries(teamConfig)) {
          lines.push(`    ${source_default.dim(key)}: ${value}`);
        }
      } else {
        lines.push(`    ${source_default.dim("(not found — run supermemory init to create)")}`);
      }
      lines.push("");
      lines.push(`  ${source_default.bold("Project Scope")} ${source_default.dim("(~/.supermemory/projects/-path-/)")}`);
      if (projectConfig) {
        for (const [key, value] of Object.entries(projectConfig)) {
          const displayValue = key === "apiKey" && typeof value === "string" ? maskApiKey(value) : String(value);
          lines.push(`    ${source_default.dim(key)}: ${displayValue}`);
        }
      } else {
        lines.push(`    ${source_default.dim("(empty)")}`);
      }
      return lines.join(`
`);
    }, flags);
  }
});

