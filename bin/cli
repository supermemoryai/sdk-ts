// src/commands/logs.ts
function formatStatusCode(code) {
  return code >= 200 && code < 300 ? source_default.green(String(code)) : source_default.red(String(code));
}
var logsListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List recent API request logs"
  },
  args: {
    period: {
      type: "string",
      description: "Time period: 24h, 7d, 30d, or all (default: 24h)"
    },
    type: {
      type: "string",
      description: "Filter by request type"
    },
    status: {
      type: "string",
      description: "Filter by status: success or error"
    },
    limit: {
      type: "string",
      description: "Max results (default: 20)"
    },
    page: {
      type: "string",
      description: "Page number (default: 1)"
    }
  },
  async handler({ args, flags }) {
    const query = {};
    query.period = parseEnumArg(args.period, "period", [
      "24h",
      "7d",
      "30d",
      "all"
    ]);
    if (args.type)
      query.type = args.type;
    query.status = parseEnumArg(args.status, "status", [
      "success",
      "error"
    ]);
    query.limit = parseIntArg(args.limit, "limit", { min: 1 }) ?? 20;
    query.page = parseIntArg(args.page, "page", { min: 1 }) ?? 1;
    const { data } = await apiRequest("/v3/analytics/requests", { query });
    output(data, () => {
      const logs = data.logs ?? [];
      if (logs.length === 0) {
        return "  No logs found.";
      }
      const pg = data.pagination;
      const header = pg ? `  Page ${pg.currentPage} of ${pg.totalPages} (${pg.totalItems} total requests)
` : "";
      const rows = logs.map((r3) => {
        const preview = r3.input ? truncate(JSON.stringify(r3.input), 60) : source_default.dim("--");
        return [
          formatRelativeTime(r3.createdAt),
          r3.type,
          formatStatusCode(r3.statusCode),
          r3.duration != null ? `${r3.duration}ms` : source_default.dim("--"),
          preview,
          source_default.dim(r3.id)
        ];
      });
      const table = formatTable(["TIMESTAMP", "TYPE", "STATUS", "LATENCY", "CONTENT", "ID"], rows);
      const hint = `

  ${source_default.dim("Tip: supermemory logs get <id> --json for full request details.")}`;
      return `${header}${table}${hint}`;
    }, flags);
  }
});
var logsGetCommand = defineCliCommand({
  meta: {
    name: "get",
    description: "Get details for a specific request log"
  },
  args: {
    id: {
      type: "positional",
      description: "Request log ID",
      required: true
    }
  },
  async handler({ args, flags }) {
    const { data } = await apiRequest("/v3/analytics/requests", {
      query: { id: args.id, limit: 1 }
    });
    const log = (data.logs ?? [])[0];
    output(log ?? data, () => {
      if (!log) {
        return `  No log found with ID ${args.id}`;
      }
      const pairs = [
        ["ID:", log.id],
        ["Timestamp:", new Date(log.createdAt).toLocaleString()],
        ["Type:", log.type],
        ["Status:", formatStatusCode(log.statusCode)],
        [
          "Latency:",
          log.duration != null ? `${log.duration}ms` : source_default.dim("--")
        ]
      ];
      if (log.keyId)
        pairs.push(["Key ID:", log.keyId]);
      const lines = [formatKeyValue(pairs)];
      if (log.input) {
        lines.push("");
        lines.push(`  ${source_default.bold("Input:")}`);
        lines.push(`  ${source_default.dim(JSON.stringify(log.input, null, 2).replace(/\n/g, `
  `))}`);
      }
      if (log.output) {
        lines.push("");
        lines.push(`  ${source_default.bold("Output:")}`);
        lines.push(`  ${source_default.dim(JSON.stringify(log.output, null, 2).replace(/\n/g, `
  `))}`);
      }
      return lines.join(`
`);
    }, flags);
  }
});
var logsCommand = defineCommand({
  meta: {
    name: "logs",
    description: "View API request logs and analytics"
  },
  subCommands: {
    list: logsListCommand,
    get: logsGetCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && ["list", "get"].includes(sub))
      return;
    await runCommand(logsListCommand, { rawArgs });
    process.stderr.write(`
  ${source_default.dim("Available commands: list, get. Run supermemory logs --help for details.")}
`);
  }
});

// src/commands/open.ts
var PAGES = [
  "console",
  "billing",
  "graph",
  "connectors",
  "settings",
  "docs",
  "keys",
  "team",
  "agents"
];
var openCommand = defineCliCommand({
  meta: {
    name: "open",
    description: "Open the Supermemory console in your browser"
  },
  noSpan: true,
  args: {
    page: {
      type: "positional",
      description: `Page to open (${PAGES.join(", ")})`,
      required: false
    },
    "no-browser": {
      type: "boolean",
      description: "Print the URL instead of opening the browser",
      default: false
    }
  },
  async handler({ args, flags, config }) {
    const page = parseEnumArg(args.page ?? "console", "page", PAGES) ?? "console";
    const path = page === "console" ? "" : `/${page}`;
    const url = `${config.consoleUrl}${path}`;
    if (args["no-browser"]) {
      output({ url }, () => url, flags);
      return;
    }
    await openBrowser(url);
    output({ url }, () => `${source_default.green("✓")} Opened ${source_default.bold(page)} in browser`, flags);
  }
});

// src/commands/plugins.ts
var import_node_fs3 = require("node:fs");
var import_node_os4 = require("node:os");
var import_node_path6 = require("node:path");
var PLUGIN_CONFIG_PATHS = {
  "claude-code": import_node_path6.join(import_node_os4.homedir(), ".claude", "settings.json"),
  cursor: import_node_path6.join(import_node_os4.homedir(), ".cursor", "settings.json"),
  opencode: import_node_path6.join(import_node_os4.homedir(), ".opencode", "config.json"),
  clawdbot: import_node_path6.join(import_node_os4.homedir(), ".clawdbot", "config.json")
};
var KNOWN_PLUGINS = ["claude-code", "cursor", "opencode", "clawdbot"];
var pluginsListCommand = defineCliCommand({
  meta: {
    name: "list",
    description: "List all plugins and their connection status"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/keys");
    output(data, () => {
      const plugins = (data.keys ?? []).filter((k2) => {
        if (!k2.metadata)
          return false;
        try {
          return JSON.parse(k2.metadata).sm_type === "plugin_auth";
        } catch {
          return false;
        }
      }).map((k2) => {
        const meta = JSON.parse(k2.metadata);
        return {
          pluginId: meta.sm_client ?? k2.name,
          keyPrefix: k2.key,
          lastUsed: k2.lastRequest,
          createdAt: k2.createdAt
        };
      });
      if (plugins.length === 0) {
        return "  No plugins connected.";
      }
      return formatTable(["PLUGIN", "KEY PREFIX", "LAST USED", "CONNECTED"], plugins.map((p) => [
        p.pluginId,
        p.keyPrefix ? maskApiKey(p.keyPrefix) : source_default.dim("--"),
        p.lastUsed ? new Date(p.lastUsed).toLocaleDateString() : source_default.dim("never"),
        new Date(p.createdAt).toLocaleDateString()
      ]));
    }, flags);
  }
});
var pluginsConnectCommand = defineCliCommand({
  meta: {
    name: "connect",
    description: "Connect a plugin and generate an API key"
  },
  args: {
    id: {
      type: "positional",
      description: "Plugin ID (claude-code, cursor, opencode, clawdbot)",
      required: true
    },
    "auto-configure": {
      type: "boolean",
      description: "Show config file path and key for auto-configuration",
      default: false
    }
  },
  async handler({ args, flags }) {
    if (!KNOWN_PLUGINS.includes(args.id)) {
      exitWithError("validation_error", `Unknown plugin "${args.id}". Available plugins: ${KNOWN_PLUGINS.join(", ")}`, flags);
    }
    const { data } = await apiRequest("/v3/auth/agent-key", {
      method: "POST",
      body: {
        name: `plugin-${args.id}`,
        pluginId: args.id,
        permission: "write"
      }
    });
    output(data, () => {
      const lines = [];
      lines.push(`${source_default.green("✓")} Connected plugin ${source_default.bold(data.pluginId)}`);
      lines.push("");
      lines.push(`  ${source_default.yellow("WARNING:")} This key will only be shown once. Copy it now.`);
      lines.push("");
      lines.push(`  ${source_default.bold(data.key)}`);
      if (args["auto-configure"]) {
        const configPath = PLUGIN_CONFIG_PATHS[args.id];
        if (configPath) {
          lines.push("");
          lines.push(source_default.dim("  ── Auto-configure ──"));
          lines.push(`  Config path: ${source_default.cyan(configPath)}`);
          lines.push(`  Exists:      ${import_node_fs3.existsSync(configPath) ? source_default.green("yes") : source_default.dim("no")}`);
          lines.push("");
          lines.push(`  Add the following key to your ${source_default.bold(args.id)} configuration:`);
          lines.push(`  ${source_default.bold(data.key)}`);
        }
      }
      return lines.join(`
`);
    }, flags);
  }
});
var pluginsRevokeCommand = defineCliCommand({
  meta: {
    name: "revoke",
    description: "Revoke the API key for a plugin"
  },
  args: {
    id: {
      type: "positional",
      description: "Plugin ID to revoke",
      required: true
    },
    yes: {
      type: "boolean",
      description: "Skip confirmation (for scripts and agents)",
      default: false
    }
  },
  async handler({ args, flags }) {
    const pluginName = args.id;
    const { data: keysData } = await apiRequest("/v3/auth/keys");
    const pluginKey = (keysData.keys ?? []).find((k2) => {
      if (!k2.metadata)
        return false;
      try {
        const meta = JSON.parse(k2.metadata);
        return meta.sm_type === "plugin_auth" && meta.sm_client === pluginName;
      } catch {
        return false;
      }
    });
    if (!pluginKey) {
      exitWithError("not_found", `No connected plugin found for "${pluginName}"`, flags);
    }
    if (!args.yes) {
      const readline = await import("node:readline");
      const rl = readline.createInterface({
        input: process.stdin,
        output: process.stderr
      });
      const answer = await new Promise((resolve4) => {
        rl.question(`${source_default.yellow("⚠")} Revoke API key for plugin ${source_default.bold(pluginName)}? [y/N] `, resolve4);
      });
      rl.close();
      if (answer.toLowerCase() !== "y") {
        exitWithError("cancelled", "Revocation cancelled.", flags, EXIT.SUCCESS);
      }
    }
    const { data } = await apiRequest(`/v3/auth/scoped-key/${pluginKey.id}`, {
      method: "DELETE"
    });
    output(data, () => `${source_default.green("✓")} Revoked API key for plugin ${source_default.dim(pluginName)}`, flags);
  }
});
var pluginsStatusCommand = defineCliCommand({
  meta: {
    name: "status",
    description: "Show detailed status of all plugins"
  },
  async handler({ flags }) {
    const { data } = await apiRequest("/v3/auth/keys");
    output(data, () => {
      const plugins = (data.keys ?? []).filter((k2) => {
        if (!k2.metadata)
          return false;
        try {
          return JSON.parse(k2.metadata).sm_type === "plugin_auth";
        } catch {
          return false;
        }
      }).map((k2) => {
        const meta = JSON.parse(k2.metadata);
        return {
          pluginId: meta.sm_client ?? k2.name,
          keyPrefix: k2.key,
          lastUsed: k2.lastRequest,
          createdAt: k2.createdAt
        };
      });
      if (plugins.length === 0) {
        return "  No plugins connected.";
      }
      const sections = plugins.map((p) => formatKeyValue([
        ["Plugin:", source_default.bold(p.pluginId)],
        [
          "Key Prefix:",
          p.keyPrefix ? maskApiKey(p.keyPrefix) : source_default.dim("--")
        ],
        [
          "Last Used:",
          p.lastUsed ? new Date(p.lastUsed).toLocaleDateString() : source_default.dim("never")
        ],
        ["Connected:", new Date(p.createdAt).toLocaleDateString()],
        [
          "Config Path:",
          PLUGIN_CONFIG_PATHS[p.pluginId] ? source_default.cyan(PLUGIN_CONFIG_PATHS[p.pluginId]) : source_default.dim("--")
        ],
        [
          "Config Exists:",
          PLUGIN_CONFIG_PATHS[p.pluginId] ? import_node_fs3.existsSync(PLUGIN_CONFIG_PATHS[p.pluginId]) ? source_default.green("yes") : source_default.dim("no") : source_default.dim("--")
        ]
      ]));
      return sections.join(`

${source_default.dim("  ──────────────────────────────────")}

`);
    }, flags);
  }
});
