    const { data } = await apiRequest(`/v3/connections/${args.id}/resources`);
    output(data, () => {
      const resources = data.resources ?? [];
      if (resources.length === 0) {
        return "  No resources found.";
      }
      return formatTable(["NAME", "TYPE", "STATUS", "SYNCED AT"], resources.map((r3) => [
        r3.name,
        r3.type,
        r3.status,
        r3.syncedAt ? formatRelativeTime(r3.syncedAt) : source_default.dim("never")
      ]));
    }, flags);
  }
});
var connectorsCommand = defineCommand({
  meta: {
    name: "connectors",
    description: "Manage external service connectors"
  },
  subCommands: {
    list: connectorsListCommand,
    connect: connectorsConnectCommand,
    sync: connectorsSyncCommand,
    history: connectorsHistoryCommand,
    disconnect: connectorsDisconnectCommand,
    resources: connectorsResourcesCommand
  },
  async run({ rawArgs }) {
    const sub = rawArgs.find((a2) => !a2.startsWith("-"));
    if (sub && [
      "list",
